            hrp.AssemblyLinearVelocity = Vector3.zero
        end

        -- 근접 감지 함수 정의
        local tooClose = false
        local function checkProximity(container, targetPos)
            if not container then return end
            for _, p in ipairs(container:GetDescendants()) do
                if p:IsA("BasePart") then
                    local pPos = p.Position
                    local horizontalDist = (Vector2.new(targetPos.X, targetPos.Z) - Vector2.new(pPos.X, pPos.Z)).Magnitude
                    if horizontalDist < 75 then
                        tooClose = true
                        return true
                    end
                end
            end
            return false
        end

        -- 보스 부재 감지 (한 번이라도 보스를 본 후, 5초 이상 사라지면 리셋)
        if not boss then
            if bossHasAppeared then -- [FIX] D키가 끝난 직후여도, 보스를 보지 못했다면 리셋하지 않음
                if not absenceStartTime then absenceStartTime = tick() end
                if tick() - absenceStartTime >= 5 then
                    hum.Health = 0 -- 5초 이상 없으면 리셋
                    break
                end
            end
        else
            bossHasAppeared = true -- 보스를 처음 발견한 시점부터 부재 감지 활성화
            absenceStartTime = nil -- 보스 발견 시 타이머 리셋
        end

        if boss and head and hrp then
            local playerUi = LocalPlayer.PlayerGui:FindFirstChild("PlayerUi")
            local zAttack = playerUi and playerUi:FindFirstChild("Left", true) and playerUi.Left:FindFirstChild("ZAttack", true)
            local cooldownObj = zAttack and zAttack:FindFirstChild("CurrentCooldown", true)
            local cooldown = (cooldownObj and cooldownObj.Value) or 0

            if cooldown == 0 then
                -- [공격 페이즈]
                if zKeyHeld == false then
                    task.wait(0.2)
                    vim:SendKeyEvent(true, Enum.KeyCode.Z, false, game)
                    zKeyHeld = true
                end

                -- 100ms 예측 텔레포트 (머리 위 15스터드 유지)
                local velocity = head.AssemblyLinearVelocity or Vector3.zero
                local targetPos = head.Position + (velocity * 0.1) + Vector3.new(0, 15, 0)
                hrp.CFrame = CFrame.new(targetPos, head.Position)
                hrp.AssemblyLinearVelocity = Vector3.zero
            else
                -- [회피/카이팅 페이즈]
                if zKeyHeld then
                    vim:SendKeyEvent(false, Enum.KeyCode.Z, false, game)
                    zKeyHeld = false
                end

                -- [FIX] Y축 무시하고 X,Z축 기준으로 2.5배 거리 (55 * 2.5 = 137.5) 유지
                local headPos = head.Position
                local hrpPos = hrp.Position
                
                -- X,Z 평면에서의 방향 계산
                local diff = (Vector3.new(hrpPos.X, 0, hrpPos.Z) - Vector3.new(headPos.X, 0, headPos.Z))
                local direction = diff.Unit
                if diff.Magnitude == 0 then direction = Vector3.new(1, 0, 0) end
                
                local safeDistance = 165
                local targetXZ = Vector2.new(headPos.X, headPos.Z) + Vector2.new(direction.X, direction.Z) * safeDistance
                local heightOffset = 15
                local safeY = math.max(hrpPos.Y, headPos.Y + heightOffset)
                local safePos = Vector3.new(targetXZ.X, safeY, targetXZ.Y)
                
                -- 모든 파트로부터 X,Z 기준 75스터드 (30 * 2.5) 이상인지 체크
                if not checkProximity(boss, safePos) then
                    checkProximity(workspace:FindFirstChild("EpicEffect2"), safePos)
                end
                
                -- [Reactive Kiting] 너무 가깝거나 너무 낮을 때만 텔레포트 (그 외엔 제자리 고정)
                if tooClose or (hrpPos.Y < headPos.Y + 15) then
                    if tooClose then
                        -- 너무 가까우면 보스로부터 더 멀어지기
                        safePos = safePos + (direction * 20)
                    end
                    hrp.CFrame = CFrame.new(safePos, head.Position)
                    hrp.AssemblyLinearVelocity = Vector3.zero
                else
                    -- 가만히 있기 (브림스톤한테 텔레포트 하지 않음)
                    hrp.AssemblyLinearVelocity = Vector3.zero
                    -- 텔레포트하지 않음 (CFrame 업데이트 생략)
                end
            end
        end
    end
    
    -- 루프 종료 시 키 떼기
    if zKeyHeld then
        vim:SendKeyEvent(false, Enum.KeyCode.Z, false, game)
    end
    SGR_Logic.isBrimRunning = false
end

