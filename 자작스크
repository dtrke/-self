local function handleEgg(target)
	for attempt = 1, 2 do
		local isFirstAttempt = (attempt == 1)
		
		Settings.SolEgg.targetName = target.Name
		Settings.SolEgg.status = isFirstAttempt and "카메라 우클릭" or "재시도: 카메라 우클릭"
		UpdateEggHUD()
		
		local initialSoundSet = captureInitialSoundSet(target)
		local pos = getWorldPosition(target)
		if not pos then return end
		
		-- 공통 실패 처리 (끼임 시 리셋 또는 포기)
		local function handleFailure(reason)
			if reason == "stuck" then
				local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
				if hum then hum.Health = 0 end
				
				if isFirstAttempt then
					Settings.SolEgg.status = "끼임 감지: 리셋 후 재시도 중..."
					UpdateEggHUD()
					LocalPlayer.CharacterAdded:Wait()
					task.wait(1)
					return "retry"
				else
					Settings.SolEgg.status = "수집 실패: 최종 포기"
					Settings.SolEgg.failCount = Settings.SolEgg.failCount + 1 -- 영구 실패 증가
					UpdateEggHUD()
					Settings.SolEgg.excludedTargets[target] = tick()
                    sendEggFailureWebhook(target.Name, "끼임 감지 (최종 포기)")
					return "giveup"
				end
			elseif reason == "aborted" then
				return "abort"
			else
				Settings.SolEgg.status = "수집 실패: 포기 (" .. tostring(reason) .. ")"
				Settings.SolEgg.failCount = Settings.SolEgg.failCount + 1 -- 영구 실패 증가
				UpdateEggHUD()
				Settings.SolEgg.excludedTargets[target] = tick()
                sendEggFailureWebhook(target.Name, reason)
				return "giveup"
			end
		end

		-- 1차 시도
		local restore = moveCameraToTarget(pos)
		task.wait(RIGHT_CLICK_DELAY)
		rightClickScreenCenter()
		if restore then restore() end
		
		Settings.SolEgg.status = isFirstAttempt and "대상 접근 중 (1차)" or "재시도: 대상 접근 중 (1차)"
		UpdateEggHUD()
		
		local ok, reason = waitInRange(target, APPROACH_TIMEOUT)
		if not ok then
			local action = handleFailure(reason)
			if action == "retry" then continue 
			elseif action == "abort" then return
			else return end
		end
		
		ok, reason = attemptE(target, initialSoundSet)
		if ok then 
			Settings.SolEgg.excludedTargets[target] = tick()
			Settings.SolEgg.successCount = Settings.SolEgg.successCount + 1
			Settings.SolEgg.collectedStatus[target.Name] = (Settings.SolEgg.collectedStatus[target.Name] or 0) + 1
			Settings.SolEgg.status = "수집 성공 (Sound 감지)"
			UpdateEggHUD()
            sendEggCollectionWebhook(target.Name)
			return 
		end
		if reason == "stuck" or reason == "aborted" then
			local action = handleFailure(reason)
			if action == "retry" then continue 
			elseif action == "abort" then return 
			else return end
		end
		
		-- 2차 시도 (우클릭 재수행)
		Settings.SolEgg.status = isFirstAttempt and "카메라 우클릭 (2차)" or "재시도: 카메라 우클릭 (2차)"
		UpdateEggHUD()
		restore = moveCameraToTarget(pos)
		task.wait(RIGHT_CLICK_DELAY)
		rightClickScreenCenter()
		if restore then restore() end
		
		Settings.SolEgg.status = isFirstAttempt and "대상 접근 중 (2차)" or "재시도: 대상 접근 중 (2차)"
		UpdateEggHUD()
		ok, reason = waitInRange(target, APPROACH_TIMEOUT)
		if not ok then
			local action = handleFailure(reason)
			if action == "retry" then continue
			elseif action == "abort" then return
			else return end
		end
		
		ok, reason = attemptE(target, initialSoundSet)
		if ok then 
			Settings.SolEgg.excludedTargets[target] = tick()
			Settings.SolEgg.successCount = Settings.SolEgg.successCount + 1
			Settings.SolEgg.collectedStatus[target.Name] = (Settings.SolEgg.collectedStatus[target.Name] or 0) + 1
			Settings.SolEgg.status = "수집 성공 (Sound 감지)"
			UpdateEggHUD()
            sendEggCollectionWebhook(target.Name)
			return 
		end
		if reason == "stuck" or reason == "aborted" then
			local action = handleFailure(reason)
			if action == "retry" then continue
			elseif action == "abort" then return
			else return end
		end
		
		-- 최종 더블클릭
		Settings.SolEgg.status = isFirstAttempt and "화면 중앙 더블클릭" or "재시도: 화면 중앙 더블클릭"
		UpdateEggHUD()
		restore = moveCameraToTarget(pos)
		task.wait(RIGHT_CLICK_DELAY)
		leftDoubleClickScreenCenter()
		if restore then restore() end
		
		ok, reason = waitForSoundOrStuck(target, initialSoundSet, FINAL_DOUBLECLICK_WAIT)
		if ok then
			Settings.SolEgg.excludedTargets[target] = tick()
			Settings.SolEgg.successCount = Settings.SolEgg.successCount + 1
			Settings.SolEgg.collectedStatus[target.Name] = (Settings.SolEgg.collectedStatus[target.Name] or 0) + 1
			Settings.SolEgg.status = "수집 성공 (더블클릭)"
			UpdateEggHUD()
            sendEggCollectionWebhook(target.Name)
			return
		end
		
		local action = handleFailure(reason)
		if action == "retry" then continue
		elseif action == "abort" then return
		else return end
	end
end

task.spawn(function()
	while true do
		if Settings.SolEgg.enabled then
            -- [NEW] Rare Egg Spawn Detection (Always active regardless of busy state)
            for _, obj in ipairs(workspace:GetChildren()) do
                if isValidEggCandidate(obj) then
                    if not notifiedSpawn[obj] then
                        local cleanName = obj.Name:gsub("_", " ")
                        if not COMMON_EGGS_ORDER[cleanName:lower()] then
                            notifiedSpawn[obj] = true
                            sendEggSpawnWebhook(obj.Name)
                        end
                    end
                end
            end

            if not Settings.SolEgg.busy then
			local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
			if root then
				local nearest, dist = nil, math.huge
				for _, obj in ipairs(workspace:GetChildren()) do
					if isValidEggCandidate(obj) then
						local pos = getWorldPosition(obj)
						if pos then
							local d = (root.Position - pos).Magnitude
							if d < dist then dist, nearest = d, obj end
						end
					end
				end
				if nearest then
					Settings.SolEgg.busy = true
					pcall(function() handleEgg(nearest) end)
					Settings.SolEgg.busy = false
				else
					Settings.SolEgg.status = "색적 중..."
					Settings.SolEgg.targetName = "없음"
					Settings.SolEgg.distance = 0
					UpdateEggHUD()
				end
			end
		end
		elseif not Settings.SolEgg.enabled then
			eggHUD.Enabled = false
		end
		task.wait(SCAN_INTERVAL)
	end
end)

