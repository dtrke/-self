function MouseLockModule.init()
    if not MouseLockModule.targetHighlight then
        local h = Instance.new("Highlight")
        h.Name = "MouseLockHighlight"
        h.FillTransparency = 0.5
        h.OutlineTransparency = 0
        h.FillColor = Color3.fromRGB(255, 255, 255)
        h.OutlineColor = Color3.fromRGB(255, 255, 255)
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.Enabled = false
        h.Parent = game:GetService("CoreGui")
        MouseLockModule.targetHighlight = h
    end
end

function MouseLockModule.getAimPart(char)
    if Settings.MouseLock.headAim and char:FindFirstChild("Head") then
        return char.Head
    end
    return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") or char:FindFirstChild("HumanoidRootPart")
end

function MouseLockModule.isTargetValid(plr)
    if not plr or not plr.Character or not plr.Character.Parent then return false end
    local hum = plr.Character:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if Settings.MouseLock.teamCheck and plr.Team == LocalPlayer.Team then return false end
    return true
end

function MouseLockModule.getClosestPlayerToMouse()
    local target, shortest = nil, math.huge
    local mousePos = Services.UserInputService:GetMouseLocation()
    
    for _, p in ipairs(Services.Players:GetPlayers()) do
        if p ~= LocalPlayer and MouseLockModule.isTargetValid(p) then
            local aimPart = MouseLockModule.getAimPart(p.Character)
            if aimPart then
                local pos, onScreen = Camera:WorldToViewportPoint(aimPart.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if dist < shortest then
                        shortest, target = dist, aimPart
                    end
                end
            end
        end
    end
    return target
end

local MouseLockConnection = nil

function MouseLockModule.stop()
    if MouseLockConnection then
        MouseLockConnection:Disconnect()
        MouseLockConnection = nil
    end
    Settings.MouseLock.isActive = false
    Settings.MouseLock.currentTarget = nil
    if MouseLockModule.targetHighlight then
        MouseLockModule.targetHighlight.Enabled = false
        MouseLockModule.targetHighlight.Adornee = nil
    end
end

function MouseLockModule.start()
    if MouseLockConnection then return end
    MouseLockModule.init()
    
    MouseLockConnection = Services.RunService.RenderStepped:Connect(function()
        -- 비활성 조건: 레그돌, 토글 OFF, 우클릭 중, 쉬프트락(마우스 잠금) 중
        local isMovingCamera = Services.UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) or 
                              Services.UserInputService.MouseBehavior ~= Enum.MouseBehavior.Default
        
        if isRagdolled or not Settings.MouseLock.isActive or isMovingCamera then
            if MouseLockModule.targetHighlight then
                MouseLockModule.targetHighlight.Enabled = false
            end
            if isRagdolled or not Settings.MouseLock.isActive then
                MouseLockModule.stop()
            end
            return
        end
        
        local target = Settings.MouseLock.currentTarget
        local playerOfTarget = target and Services.Players:GetPlayerFromCharacter(target.Parent)
        
        -- 타겟 유효성 검사 (죽었거나 나갔거나 팀이 바뀌었거나)
        if not target or not target.Parent or not MouseLockModule.isTargetValid(playerOfTarget) then
            if Settings.MouseLock.singlePlayer then
                MouseLockModule.stop()
                return
            else
                Settings.MouseLock.currentTarget = MouseLockModule.getClosestPlayerToMouse()
                target = Settings.MouseLock.currentTarget
                if not target then
                    if MouseLockModule.targetHighlight then MouseLockModule.targetHighlight.Enabled = false end
                    return
                end
            end
        end
        
        -- 하이라이트 적용
        if MouseLockModule.targetHighlight then
            MouseLockModule.targetHighlight.Adornee = target.Parent
            MouseLockModule.targetHighlight.Enabled = true
        end

        -- 화면상 마우스 포인터 이동 (수정됨: 정밀 좌표 및 Fallback 적용)
        local torsoPos, onScreen = Camera:WorldToScreenPoint(target.Position)
        if onScreen then
            local mousePos = Services.UserInputService:GetMouseLocation()
            local sens = 0.5
            local moveX = (torsoPos.X - mousePos.X) * sens
            local moveY = (torsoPos.Y - mousePos.Y) * sens
            
            local finalX = math.floor(moveX + (moveX > 0 and 0.5 or -0.5))
            local finalY = math.floor(moveY + (moveY > 0 and 0.5 or -0.5))

            if mousemoverel then
                mousemoverel(finalX, finalY)
            elseif Services.VirtualInputManager then
                Services.VirtualInputManager:SendMouseMoveEvent(mousePos.X + finalX, mousePos.Y + finalY, workspace)
            end
        else
            -- 화면 밖으로 나가면 (단일 플레이어 모드가 아니면) 재검색
            if not Settings.MouseLock.singlePlayer then
                Settings.MouseLock.currentTarget = MouseLockModule.getClosestPlayerToMouse()
            else
                if MouseLockModule.targetHighlight then MouseLockModule.targetHighlight.Enabled = false end
            end
        end
    end)
end

Services.UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Settings.MouseLock.key and Settings.MouseLock.enabled then
        Settings.MouseLock.isActive = not Settings.MouseLock.isActive
