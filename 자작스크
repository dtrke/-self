local function SmoothMouseMoveToAbsolute(targetAbsolutePosition, duration)
    local uis = game:GetService("UserInputService")
    local startPos = uis:GetMouseLocation()
    local totalDelta = targetAbsolutePosition - startPos
    local startTime = tick()
    local conn
    local lastAlpha = 0
    
    conn = game:GetService("RunService").RenderStepped:Connect(function()
        local elapsed = tick() - startTime
        if elapsed >= duration then
            local remainingAlpha = 1 - lastAlpha
            if remainingAlpha > 0 and mousemoverel then
                local finalMove = totalDelta * remainingAlpha
                mousemoverel(finalMove.X, finalMove.Y)
            end
            if conn then conn:Disconnect() end
            return
        end
        local alpha = elapsed / duration
        local easeAlpha = -(math.cos(math.pi * alpha) - 1) / 2
        
        local moveAlpha = easeAlpha - lastAlpha
        lastAlpha = easeAlpha
        
        local stepDelta = totalDelta * moveAlpha
        if mousemoverel then
            mousemoverel(stepDelta.X, stepDelta.Y)
        end
    end)
    task.wait(duration)
end

