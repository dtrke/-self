local lastSuccessCount = -1
local function UpdateCollectionListUI()
    if lastSuccessCount == Settings.SolEgg.successCount then return end
    lastSuccessCount = Settings.SolEgg.successCount

    -- 기존 목록 초기화
    for _, child in ipairs(collectionListHUD:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    -- 데이터 정렬 (요청된 순서 -> 그 외는 갯수 많은 순)
    local sortedEggs = {}
    for name, count in pairs(Settings.SolEgg.collectedStatus) do
        table.insert(sortedEggs, {name = name:gsub("_", " "), count = count})
    end
    table.sort(sortedEggs, function(a, b) 
        local orderA = COMMON_EGGS_ORDER[a.name:lower()] or 999
        local orderB = COMMON_EGGS_ORDER[b.name:lower()] or 999
        
        if orderA ~= orderB then
            return orderA < orderB
        end
        return a.count > b.count 
    end)

    -- 목록 생성 (컴팩트하게)
    for i, data in ipairs(sortedEggs) do
        local frame = Instance.new("Frame", collectionListHUD)
        frame.Size = UDim2.new(0.95, 0, 0, 22) -- 높이 축소
        frame.BackgroundTransparency = 0.4
        frame.BorderSizePixel = 0
        frame.LayoutOrder = i

        -- 그라디언트 계산 (진한 파란색 -> 하얀색)
        local t = #sortedEggs > 1 and (i - 1) / (#sortedEggs - 1) or 0
        local startColor = Color3.fromRGB(0, 80, 200) -- 진한 파란색
        local endColor = Color3.fromRGB(240, 240, 240) -- 연한 하얀색
        local lerpedColor = startColor:Lerp(endColor, t)
        
        frame.BackgroundColor3 = lerpedColor
        
        local corner = Instance.new("UICorner", frame)
        corner.CornerRadius = UDim.new(0, 4)

        local stroke = Instance.new("UIStroke", frame)
        stroke.Color = Color3.fromRGB(0, 0, 0)
        stroke.Thickness = 1
        stroke.Transparency = 0.8

        local label = Instance.new("TextLabel", frame)
        label.Size = UDim2.new(1, -10, 1, 0)
        label.Position = UDim2.new(0, 5, 0, 0)
        label.BackgroundTransparency = 1
        label.Text = string.format("▣ %s = %d ▣", data.name, data.count)
        label.TextColor3 = (t > 0.55) and Color3.fromRGB(20, 20, 20) or Color3.fromRGB(255, 255, 255)
        label.Font = Enum.Font.GothamBold
        label.TextSize = 13 -- 소폭 증가
        label.TextXAlignment = Enum.TextXAlignment.Center
    end
end

