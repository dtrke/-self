local ObstacleManager = {
    hiddenParts = {} -- [part] = {transparency, canCollide}
}

function ObstacleManager.restoreAll()
    for part, data in pairs(ObstacleManager.hiddenParts) do
        if part and part.Parent then
            part.Transparency = data.transparency
            part.CanCollide = data.canCollide
        end
    end
    table.clear(ObstacleManager.hiddenParts)
end

function ObstacleManager.clearObstaclesToTarget(targetPart)
    if not Settings.Aim.clearObstacles or not targetPart then
        ObstacleManager.restoreAll()
        return
    end

    local character = LocalPlayer.Character
    if not character then return end

    local startPos = Camera.CFrame.Position
    local targetPos = targetPart.Position
    local direction = targetPos - startPos
    local distance = direction.Magnitude
    local range = math.clamp(Settings.Aim.clearObstaclesRange or 5, 0, 50)
    
    -- 기본 필터 (카메라와 타겟 사이를 무시해야 하는 것들)
    local ignoreList = {character, targetPart.Parent, workspace.Terrain}

    -- [보호] 현재 내가 밟고 있는 바닥 (공허 방지)
    if not Settings.Aim.clearObstaclesIncludingFloor then
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if hrp then
            -- 캐릭터 발 밑으로 레이캐스트하여 바닥 파트를 찾음
            local floorRay = RaycastParams.new()
            floorRay.FilterType = Enum.RaycastFilterType.Exclude
            floorRay.FilterDescendantsInstances = {character}
            local result = workspace:Raycast(hrp.Position, Vector3.new(0, -10, 0), floorRay)
            if result and result.Instance then
                table.insert(ignoreList, result.Instance)
            end
        end
    end

    -- 투명벽이나 특정 조건의 파트도 가차없이 지우기 위해 물리적인 '상자(Box)' 기반 스캔(Spatial Query) 사용
    -- 지정된 범위(Range)만큼의 가로세로를 가지고, 나와 타겟까지의 거리를 길이로 하는 거대한 상자를 만듭니다.
    local thickness = (range == 0) and 0.5 or (range * 2)
    local centerPos = startPos + (direction / 2)
    local boxCFrame = CFrame.lookAt(centerPos, targetPos)
    local boxSize = Vector3.new(thickness, thickness, distance)
    
    local overlapParams = OverlapParams.new()
    overlapParams.FilterType = Enum.RaycastFilterType.Exclude
    overlapParams.FilterDescendantsInstances = ignoreList
    overlapParams.MaxParts = 1000 -- 안전을 위해 최대 1000개 파트까지 탐색

    -- 상자 내부와 겹치는 "모든" 파트들을 무조건 가져옵니다 (투명도/물리 충돌 여부 무관)
    local obscuringParts = workspace:GetPartBoundsInBox(boxCFrame, boxSize, overlapParams)
    
    local currentHitParts = {}

    -- 찾은 모든 장애물들을 일괄적으로 무형/투명화 처리
    for _, part in ipairs(obscuringParts) do
        if part:IsA("BasePart") then
            if not ObstacleManager.hiddenParts[part] then
                ObstacleManager.hiddenParts[part] = {
                    transparency = part.Transparency,
                    canCollide = part.CanCollide
                }
            end
            part.Transparency = 1
            part.CanCollide = false
            currentHitParts[part] = true
        end
    end

    -- 이번 프레임에서 가리지 않는 이전 파트들은 원래 상태로 복구
    for part, data in pairs(ObstacleManager.hiddenParts) do
        if not currentHitParts[part] then
            if part and part.Parent then
                part.Transparency = data.transparency
                part.CanCollide = data.canCollide
            end
            ObstacleManager.hiddenParts[part] = nil
        end
    end
end

