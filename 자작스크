local function SaveConfig()
    pcall(function()
        ConfigSystem.SavedStates["_AUTO_LOAD_ENABLED"] = ConfigSystem.AutoLoad
        if writefile then
            writefile(CONFIG_FILE, HttpService:JSONEncode(ConfigSystem.SavedStates))
        end
    end)
end

local original_UI_New = UI.New
UI.New = function(...)
    local page = original_UI_New(...)
    
    local function hookComponent(compName)
        local originalComp = page[compName]
        if not originalComp then return end
        
        page[compName] = function(options)
            local cName = options.Text
            if not cName then return originalComp(options) end
            
            local originalCallback = options.Callback
            
            -- 컴포넌트 생성 시 초기 렌더링 값 덮어씌우기 (텔레포트 로딩 & 자동복구 켜짐 한정)
            if ConfigSystem.IsTeleportLoad and ConfigSystem.AutoLoad and ConfigSystem.SavedStates[cName] ~= nil then
                local savedVal = ConfigSystem.SavedStates[cName]
                options.Def = savedVal
                options.Default = savedVal
                options.Type = savedVal
                options.Enabled = savedVal
            end
            
            local wrappedCallback = function(val)
                ConfigSystem.SavedStates[cName] = val
                SaveConfig()
                if originalCallback then
                    originalCallback(val)
                end
            end
            
            options.Callback = wrappedCallback
            
            local compObj = originalComp(options)
            ConfigSystem.Components[cName] = compObj
            ConfigSystem.Callbacks[cName] = wrappedCallback
            return compObj
        end
    end
    
    hookComponent("Toggle")
    hookComponent("Slider")
    hookComponent("Dropdown")
    hookComponent("TextField")
    
    return page
end

