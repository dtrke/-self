local function showPremiumIndicator(x, y)
    local sg = Instance.new("ScreenGui")
    sg.Name = "TacticalIndicatorGui"
    sg.IgnoreGuiInset = true
    sg.Parent = LocalPlayer.PlayerGui
    
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0, 40, 0, 40)
    container.Position = UDim2.new(0, x, 0, y)
    container.AnchorPoint = Vector2.new(0.5, 0.5)
    container.BackgroundTransparency = 1
    container.Parent = sg

    local color = Color3.fromRGB(0, 160, 255) -- [BLUE] 요청하신 파란색 테마

    local dot = Instance.new("Frame")
    dot.Size, dot.Position = UDim2.new(0, 4, 0, 4), UDim2.new(0.5, 0, 0.5, 0)
    dot.AnchorPoint, dot.BackgroundColor3 = Vector2.new(0.5, 0.5), color
    dot.BorderSizePixel = 0
    dot.Parent = container
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local ring = Instance.new("Frame")
    ring.Size, ring.Position = UDim2.new(0, 20, 0, 20), UDim2.new(0.5, 0, 0.5, 0)
    ring.AnchorPoint, ring.BackgroundTransparency = Vector2.new(0.5,0.5), 1
    ring.Parent = container
    local stroke = Instance.new("UIStroke")
    stroke.Color, stroke.Thickness = color, 1.2
    stroke.Parent = ring
    Instance.new("UICorner", ring).CornerRadius = UDim.new(1, 0)

    local function createLine(size)
        local line = Instance.new("Frame")
        line.Size, line.Position, line.AnchorPoint = size, UDim2.new(0.5, 0, 0.5, 0), Vector2.new(0.5, 0.5)
        line.BackgroundColor3, line.BorderSizePixel = color, 0
        line.Parent = container
        return line
    end
    createLine(UDim2.new(0, 30, 0, 1))
    createLine(UDim2.new(0, 1, 0, 30))

    container.Size = UDim2.new(0, 10, 0, 10)
    local expandInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    Services.TweenService:Create(container, expandInfo, {Size = UDim2.new(0, 45, 0, 45)}):Play()

    task.delay(0.4, function()
        local fadeInfo = TweenInfo.new(0.6, Enum.EasingStyle.Linear)
        for _, obj in pairs(container:GetDescendants()) do
            if obj:IsA("Frame") then Services.TweenService:Create(obj, fadeInfo, {BackgroundTransparency = 1}):Play()
            elseif obj:IsA("UIStroke") then Services.TweenService:Create(obj, fadeInfo, {Transparency = 1}):Play() end
        end
        task.wait(0.6)
        sg:Destroy()
    end)
end

local function clickExactly(button)
    if button and button.AbsoluteSize.X > 0 and button.Visible then
        local absPos = button.AbsolutePosition
        local absSize = button.AbsoluteSize
        local topBarHeight = game:GetService("GuiService"):GetGuiInset().Y
        local centerX = absPos.X + (absSize.X / 2)
        local centerY = absPos.Y + (absSize.Y / 2) + topBarHeight

        showPremiumIndicator(centerX, centerY)
        Services.VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 0)
        task.wait(0.05)
        Services.VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 0)
        return true
    end
    return false
end

local function useSpecificItemByName(itemName)
    local inventory = LocalPlayer.PlayerGui.MainInterface:FindFirstChild("Inventory")
    if not inventory then return false end
    
    local scrollingFrame = inventory:FindFirstChild("Items") and inventory.Items:FindFirstChild("ItemGrid") and inventory.Items.ItemGrid:FindFirstChild("ItemGridScrollingFrame")
    if not scrollingFrame then return false end

    local targetItem = nil
    for _, item in pairs(scrollingFrame:GetChildren()) do
        if item.Name == itemName or item:FindFirstChild(itemName, true) then
            targetItem = item
        else
            for _, desc in pairs(item:GetDescendants()) do
                if desc:IsA("TextLabel") and string.find(desc.Text, itemName) then
                    targetItem = item
                    break
                end
            end
        end
        if targetItem then break end
    end

    if targetItem then
        clickExactly(targetItem)
        task.wait(0.5)
        local itemIndex = inventory:WaitForChild("Index"):WaitForChild("ItemIndex")
        local useAmount = itemIndex:WaitForChild("UseHolder"):WaitForChild("UseAmount")
        local useButton = itemIndex.UseHolder:WaitForChild("UseButton")
        
        if useAmount.Text == "1" then
            clickExactly(useButton)
        else
            useAmount.Text = "1"
            if useAmount:IsA("TextBox") then useAmount:ReleaseFocus() end
            task.wait(0.25)
            clickExactly(useButton)
        end
        return true
    end
    return false
end

local function performBiomeAutoSequence()
    local mainInterface = LocalPlayer.PlayerGui:FindFirstChild("MainInterface")
    local inventory = mainInterface and mainInterface:FindFirstChild("Inventory")
    if not inventory then return end

    -- 1. 인벤토리 열기
    if not inventory.Visible then
        local sideButtons = mainInterface:FindFirstChild("SideButtons")
        if sideButtons then
            for _, btn in pairs(sideButtons:GetChildren()) do
                if btn.Name == "TextButton" and btn:FindFirstChild("Usage") and btn.Usage.Text == "Inventory" then
                    clickExactly(btn)
                    task.wait(0.8)
                    break
                end
            end
        end
    end
    if not inventory.Visible then return end
    task.wait(0.5)

    -- 2. ItemsTab 클릭
    local itemsTab = inventory:FindFirstChild("Items") and inventory.Items:FindFirstChild("ItemsTab")
    if itemsTab then clickExactly(itemsTab) end
    task.wait(0.3)

    -- 3. 카테고리(30001) 클릭
    local quickCategory = inventory:FindFirstChild("QuickCategory")
    if quickCategory then
        for _, btn in pairs(quickCategory:GetChildren()) do
            if btn:IsA("ImageButton") and btn.LayoutOrder == 30001 then
                clickExactly(btn)
                break
            end
        end
    end

    -- 4. 아이템 사용 릴레이
    task.wait(2)
    useSpecificItemByName("Strange Controller")
    
    task.wait(0.75)
    useSpecificItemByName("Biome Randomizer")
end

task.spawn(function()
