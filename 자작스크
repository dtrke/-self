local function getAttachmentPart(character, partName)
    if not character then return nil end
    local part = character:FindFirstChild(partName)
    if part then return part end
    
    -- R15 fallbacks
    if partName == "Torso" then
        return character:FindFirstChild("UpperTorso") or character:FindFirstChild("LowerTorso")
    elseif partName == "Left Arm" then
        return character:FindFirstChild("LeftUpperArm")
    elseif partName == "Right Arm" then
        return character:FindFirstChild("RightUpperArm")
    elseif partName == "Left Leg" then
        return character:FindFirstChild("LeftUpperLeg")
    elseif partName == "Right Leg" then
        return character:FindFirstChild("RightUpperLeg")
    end
    return nil
end



-- [내부 함수] 현재 캐릭터 상태 백업 (복구용)
local function BackupAvatar(character)
    if not character then return end
    local backup = {
        BodyColors = nil,
        Pants = nil,
        Shirt = nil,
        CharacterMeshes = {},
        HeadMeshes = {},
        FaceTexture = nil
    }
    
    local bc = character:FindFirstChildOfClass("BodyColors")
    if bc then
        backup.BodyColors = {
            HeadColor3 = bc.HeadColor3,
            LeftArmColor3 = bc.LeftArmColor3,
            RightArmColor3 = bc.RightArmColor3,
            LeftLegColor3 = bc.LeftLegColor3,
            RightLegColor3 = bc.RightLegColor3,
            TorsoColor3 = bc.TorsoColor3,
        }
    end
    
    local p = character:FindFirstChildOfClass("Pants")
    if p then backup.Pants = p.PantsTemplate end
    
    local s = character:FindFirstChildOfClass("Shirt")
    if s then backup.Shirt = s.ShirtTemplate end

    -- CharacterMesh 백업
    for _, obj in ipairs(character:GetChildren()) do
        if obj:IsA("CharacterMesh") then
            table.insert(backup.CharacterMeshes, {
                MeshId = obj.MeshId,
                BodyPart = obj.BodyPart,
                BaseTextureId = obj.BaseTextureId,
                OverlayTextureId = obj.OverlayTextureId,
                Name = obj.Name
            })
        end
    end

    -- Head Mesh 백업
    local head = character:FindFirstChild("Head")
    if head then
        for _, obj in ipairs(head:GetChildren()) do
            if obj:IsA("SpecialMesh") or obj:IsA("Mesh") then
                local meshData = { ClassName = obj.ClassName, Name = obj.Name }
                pcall(function() meshData.MeshId = obj.MeshId end)
                pcall(function() meshData.TextureId = obj.TextureId end)
                pcall(function() meshData.Scale = obj.Scale end)
                pcall(function() meshData.VertexColor = obj.VertexColor end)
                pcall(function() meshData.Offset = obj.Offset end)
                pcall(function() meshData.MeshType = obj.MeshType end)
                table.insert(backup.HeadMeshes, meshData)
            elseif obj:IsA("Decal") and obj.Name == "face" then
                backup.FaceTexture = obj.Texture
            end
        end
    end
    
    Settings.AvatarChanger.persistentBackup = backup
end

