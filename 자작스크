-- Boss Bind Logic (Smooth Update)
Services.RunService.Heartbeat:Connect(function()
    if Settings.SGR.bossBindEnabled then
        local entities = workspace:FindFirstChild("Entities")
        if entities then
            for _, entity in ipairs(entities:GetChildren()) do
                -- 플레이어 제외 체크
                if game.Players:GetPlayerFromCharacter(entity) then continue end
                
                local character = LocalPlayer.Character
                if character and character:FindFirstChild("HumanoidRootPart") then
                    local hrp = character.HumanoidRootPart
                    local targetPos = hrp.CFrame * CFrame.new(0, 0, -Settings.SGR.bossBindDistance)
                    
                    if entity:IsA("Model") then
                        entity:PivotTo(targetPos)
                        -- [QoL] 물리적 툭툭 끊김 방지: 벨로시티 초기화
                        local primary = entity.PrimaryPart or entity:FindFirstChild("HumanoidRootPart") or entity:FindFirstChildWhichIsA("BasePart")
                        if primary then
                            primary.AssemblyLinearVelocity = Vector3.zero
                            primary.AssemblyAngularVelocity = Vector3.zero
                        end
                    elseif entity:IsA("BasePart") then
                        entity.CFrame = targetPos
                        entity.AssemblyLinearVelocity = Vector3.zero
                        entity.AssemblyAngularVelocity = Vector3.zero
                    end
                end
            end
        end
    end
end)

