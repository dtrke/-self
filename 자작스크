        -- 실시간 감지 (Option 1)
        local entities = workspace:FindFirstChild("Entities")
        if entities then
            table.insert(connections, entities.ChildAdded:Connect(checkEntity))
        end
        table.insert(connections, workspace.ChildAdded:Connect(checkEntity))

        local lastHP = hum.Health
        local timeWithoutChange = 0
        
        while Settings.SGR.autoWaveEnabled do
            task.wait(1)
            local currentHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
            if not currentHum or currentHum.Health <= 0 then
                break -- 죽으면 루프 종료
            end
            
            -- 보조 폴링 (Option 3)
            if entities and entities:FindFirstChild("Impostor") then
                currentHum.Health = 0
                break
            end

            if math.abs(currentHum.Health - lastHP) >= 1 then
                lastHP = currentHum.Health
                timeWithoutChange = 0 -- HP 변화가 있으면 타이머 리셋
            else
                timeWithoutChange = timeWithoutChange + 1
                if timeWithoutChange >= 30 then
                    currentHum.Health = 0 -- 30초 경과 시 스스로 재설정
                    break
                end
            end
        end

        -- 연결 해제
        for _, c in ipairs(connections) do
            c:Disconnect()
        end
    end)
    
    task.wait(1)
    if not Settings.SGR.autoWaveEnabled then return end
    
    local vim = game:GetService("VirtualInputManager")
    
