local myScriptUrl = "https://raw.githubusercontent.com/dtrke/-self/refs/heads/main/%EC%9E%90%EC%9E%91%EC%8A%A4%ED%81%AC"

-- 1. 처음 스크립트를 켰을 때, 익스플로잇 workspace 폴더에 '링크 파일' 자동 생성 (이미 있으면 생성 안함)
local function UpdatePersistence()
    if writefile and isfile then
        if Settings.Persistence.enabled then
            if not isfile("ZajakScript_Loader.lua") then
                local loaderCode = 'loadstring(game:HttpGet("' .. myScriptUrl .. '"))()'
                writefile("ZajakScript_Loader.lua", loaderCode)
            end
        else
            if isfile("ZajakScript_Loader.lua") then
                pcall(function() delfile("ZajakScript_Loader.lua") end)
            end
        end
    end
    
    if queue_on_teleport then
        if not Settings.Persistence.enabled then
            pcall(function() queue_on_teleport("") end)
        end
    end
end

-- 초기 실행 시 퍼시스턴스 업데이트
task.spawn(UpdatePersistence)

-- 2. 게임 내에서 다른 서버/장소로 텔레포트할 때만 스크립트를 링크에서 다시 불러옵니다.
local queue_on_teleport = queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport) or getgenv().queue_on_teleport
if queue_on_teleport then
    local teleportConn
    teleportConn = game:GetService("Players").LocalPlayer.OnTeleport:Connect(function(State)
        -- 퍼시스턴스(자동 실행)가 켜져 있을 때만 다음 서버로 스크립트를 전달합니다.
        if Settings.Persistence.enabled and (State == Enum.TeleportState.Started or State == Enum.TeleportState.InProgress) then
            local TELEPORT_AUTO_LOAD = [[
                if not game:IsLoaded() then game.Loaded:Wait() end
                task.wait(1)
                pcall(function()
                    if getgenv then getgenv().IS_TELEPORT_LOAD = true end
                    loadstring(game:HttpGet("]] .. myScriptUrl .. [["))()
                end)
            ]]
            pcall(function()
                queue_on_teleport(TELEPORT_AUTO_LOAD)
            end)
            if teleportConn then teleportConn:Disconnect() end
        end
    end)
end

