local FlyModule = {}

function FlyModule.cleanup()
    for _, conn in pairs(Settings.Fly.connections) do
        if conn then conn:Disconnect() end
    end
    Settings.Fly.connections = {}
    
    if Settings.Fly.BV then Settings.Fly.BV:Destroy() Settings.Fly.BV = nil end
    if Settings.Fly.BG then Settings.Fly.BG:Destroy() Settings.Fly.BG = nil end
end

function FlyModule.start()
    if Settings.Fly.isFlying then return end
    Settings.Fly.isFlying = true

    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")

    Settings.Fly.BV = Instance.new("BodyVelocity")
    Settings.Fly.BV.Velocity = Vector3.zero
    Settings.Fly.BV.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    Settings.Fly.BV.Parent = hrp

    Settings.Fly.BG = Instance.new("BodyGyro")
    Settings.Fly.BG.CFrame = hrp.CFrame
    Settings.Fly.BG.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    Settings.Fly.BG.P = 9e4
    Settings.Fly.BG.Parent = hrp

    if humanoid then humanoid.PlatformStand = true end

    local function onKeyPress(KEY)
        KEY = KEY:lower()
        local CTRL = Settings.Fly.CONTROL
        if KEY == "w" then CTRL.F = 1
        elseif KEY == "s" then CTRL.B = -1
        elseif KEY == "a" then CTRL.L = -1
        elseif KEY == "d" then CTRL.R = 1
        elseif KEY == "e" then CTRL.Q = 1
        elseif KEY == "q" then CTRL.E = -1 end
    end

    local function onKeyRelease(KEY)
        KEY = KEY:lower()
        local CTRL = Settings.Fly.CONTROL
        if KEY == "w" then CTRL.F = 0
        elseif KEY == "s" then CTRL.B = 0
        elseif KEY == "a" then CTRL.L = 0
        elseif KEY == "d" then CTRL.R = 0
        elseif KEY == "e" then CTRL.Q = 0
        elseif KEY == "q" then CTRL.E = 0 end
    end

    table.insert(Settings.Fly.connections, Services.UserInputService.InputBegan:Connect(function(input, processed)
        if not processed and input.UserInputType == Enum.UserInputType.Keyboard then
            onKeyPress(input.KeyCode.Name)
        end
    end))

    table.insert(Settings.Fly.connections, Services.UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Keyboard then
            onKeyRelease(input.KeyCode.Name)
        end
    end))

    task.spawn(function()
        while Settings.Fly.isFlying do
            task.wait()
            local CTRL = Settings.Fly.CONTROL
            local moveDirection = Vector3.new(CTRL.R + CTRL.L, CTRL.Q + CTRL.E, CTRL.F + CTRL.B)

            if moveDirection.Magnitude > 0 then
                moveDirection = moveDirection.Unit
                local camCF = Camera.CFrame
                Settings.Fly.BV.Velocity = ((camCF.LookVector * moveDirection.Z) +
                                           (camCF.RightVector * moveDirection.X) +
                                           (camCF.UpVector * moveDirection.Y)) * Settings.Fly.speed * 5
            else
                Settings.Fly.BV.Velocity = Vector3.zero
            end

            Settings.Fly.BG.CFrame = Camera.CFrame
        end

        if humanoid then humanoid.PlatformStand = false end
        FlyModule.cleanup()
    end)
end

function FlyModule.stop()
    if not Settings.Fly.isFlying then return end
    Settings.Fly.isFlying = false
end

