local GlobalNotifReadyAt = tick() + 2

local original_UI_New = UI.New
UI.New = function(...)
    local page = original_UI_New(...)
    
            local function hookComponent(compName)
        local originalComp = page[compName]
        if not originalComp then return end
        
        page[compName] = function(options)
            local originalCallback = options.Callback
            local status, result = pcall(function()
                local rawName = options.Text or ""
                local cName = rawName:gsub("^%s*(.-)%s*$", "%1") -- 공백 제거
                if cName == "" then return originalComp(options) end
                
                local isPermanent = (cName == "에그 알림 웹후크 URL" or cName == "웹후크 URL")
                local hasSyncedValue = false
                local syncedValue = nil
                
                -- [데이터 로드]
                if isPermanent then
                    if ConfigSystem.PermanentStates[cName] ~= nil then
                        syncedValue = ConfigSystem.PermanentStates[cName]
                        hasSyncedValue = true
                        options.Def = syncedValue
                        options.Default = syncedValue
                    end
                elseif ConfigSystem.IsTeleportLoad and ConfigSystem.AutoLoad and ConfigSystem.SavedStates[cName] ~= nil then
                    syncedValue = ConfigSystem.SavedStates[cName]
                    hasSyncedValue = true
                    
                    -- 타입 강제 변환 (라이브러리 충돌 방지)
                    if compName == "TextField" then
                        syncedValue = tostring(syncedValue)
                        options.Text = syncedValue .. " - 동기화됨"
                        options.Def = syncedValue
                    else
                        syncedValue = (syncedValue == true)
                        options.Enabled = syncedValue
                        options.Def = syncedValue
                    end
                end
                
                -- [콜백 래퍼]
                local initialCall = true
                local wrappedCallback = function(val)
                    if initialCall then
                        initialCall = false
                        if hasSyncedValue and (val == "" or val == nil or val == false) then
                            return
                        end
                    end

                    if isPermanent then
                        ConfigSystem.PermanentStates[cName] = val
                    else
                        ConfigSystem.SavedStates[cName] = val
                    end
                    
                    SaveConfig()
                    if originalCallback then
                        originalCallback(val)
                    end
                    
                    if tick() > GlobalNotifReadyAt then
                        if compName == "Toggle" then
                            local stateText = val and "활성화됨" or "비활성화됨"
                            notif:SendNotification('SkyBlueInfo', cName .. ' ' .. stateText, 2)
                        elseif compName == "Button" then
                            notif:SendNotification('SkyBlueInfo', cName .. ' 실행됨', 2)
                        end
                    end
                end
                
                options.Callback = wrappedCallback
                
                -- [컴포넌트 생성]
                local compObj = originalComp(options)
                
                -- [동기화 강제 적용]
                if hasSyncedValue then
                    task.spawn(function()
                        task.wait(0.5)
                        pcall(function()
                            if compName == "TextField" and compObj and compObj.SetText then
                                compObj:SetText(syncedValue)
                            elseif compName == "Toggle" and compObj and compObj.SetState then
                                compObj:SetState(syncedValue)
                            end
                            if originalCallback then
                                -- [버그 수정] 아바타 변경 기능은 InitCharacter에서 1초 대기 후 별도로 실행하므로,
                                -- 초기 동기화 시점(서버 진입 중)에는 콜백 호출을 생략하여 중복 실행 및 깜빡임 방지
                                if not (compName == "Toggle" and cName == "아바타 변경 ON/OFF" and ConfigSystem.IsTeleportLoad) then
                                    originalCallback(syncedValue)
                                end
                            end
                        end)
                    end)
                end
                
                ConfigSystem.Components[cName] = compObj
                ConfigSystem.Callbacks[cName] = wrappedCallback
                return compObj
            end)
            
            if not status then
                warn("ConfigSystem Hook Error [" .. tostring(compName) .. "]: " .. tostring(result))
                return originalComp(options) -- 오류 시 원본 생성 시도 (UI 유실 방지)
            end
            return result
        end
    end
    
    hookComponent("Toggle")
    hookComponent("Slider")
    hookComponent("Dropdown")
    hookComponent("TextField")
    hookComponent("Button")
    
    return page
end

