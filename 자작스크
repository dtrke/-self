local function EnsureMusicFile(Name)
    local filename = Name
    local filetype = '.mp3'
    local filepath = filename .. filetype

    local success = pcall(function()
        return readfile(filepath)
    end)

    if not success then
        notif:SendNotification('Info', 'Downloading ' .. filename .. filetype, 7)
        local filep = game:HttpGet('https://github.com/dtrke/musics/raw/refs/heads/main/' .. filename .. filetype)
        if filep then
            writefile(filepath, filep)
            notif:SendNotification('Success', 'Downloaded!', 3)
        end
    end

    local snd = game.CoreGui:FindFirstChild(Name)
    if not snd then
        snd = Instance.new('Sound', game.CoreGui)
        snd.Name = Name
        snd.SoundId = getcustomasset(filepath)
        snd.Looped = true
    end
    return snd
end

local function PlayFunnyMusic()
    for _, child in pairs(game.CoreGui:GetChildren()) do
        if child:IsA("Sound") and (child.Name == "LifeIsKinetics" or child.Name == "Rebelo" or child.Name == "NoMercy" or child.Name == "Edu") then
            child:Pause()
        end
    end
    if getgenv().FunnyMusicPlaying and getgenv().CurrentFunnyMusic ~= "" then
        local targetSnd = EnsureMusicFile(getgenv().CurrentFunnyMusic)
        if targetSnd then
            targetSnd.Volume = getgenv().FunnyMusicVolume
            if not targetSnd.IsPlaying then
                targetSnd:Play()
            end
        end
    end
end

