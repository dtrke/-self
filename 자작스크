    trail.Attachment1 = Instance.new("Attachment", orb)
    trail.Attachment1.Position = Vector3.new(0, 0, -0.6)
    trail.Enabled = true

    return orb
end

function NoclipModule.destroyOrbs()
    for _, orb in ipairs(Settings.Noclip.orbitParts) do
        if orb and orb.Parent then orb:Destroy() end
    end
    table.clear(Settings.Noclip.orbitParts)
end

function NoclipModule.setNoclip(state)
    Settings.Noclip.enabled = state
    if state and Settings.Noclip.orbsEnabled then
        for i = 1, 3 do
            table.insert(Settings.Noclip.orbitParts, NoclipModule.createOrb(i))
        end
    elseif not state then
        NoclipModule.destroyOrbs()
    end
end

function NoclipModule.setOrbs(state)
    Settings.Noclip.orbsEnabled = state
    if state and Settings.Noclip.enabled then
        for i = 1, 3 do
            table.insert(Settings.Noclip.orbitParts, NoclipModule.createOrb(i))
        end
    else
        NoclipModule.destroyOrbs()
    end
end

-- Noclip 업데이트 루프 (최적화됨)
Services.RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Noclip 적용
    if Settings.Noclip.enabled then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end

    -- 구체 위치 업데이트
    if Settings.Noclip.orbsEnabled and #Settings.Noclip.orbitParts > 0 then
        local t = tick() * 3
        local orbCount = #Settings.Noclip.orbitParts
        
        for i, orb in ipairs(Settings.Noclip.orbitParts) do
            local offset = (i - 1) * (math.pi * 2 / orbCount)
            local x = math.cos(t + offset) * 4.5
            local z = math.sin(t + offset) * 4.5
            local y = math.sin((t + offset) * 1.5) * 0.7 + 0.5
            orb.Position = orb.Position:Lerp(hrp.Position + Vector3.new(x, y, z), Settings.Noclip.followSpeed)
        end
    end
end)

