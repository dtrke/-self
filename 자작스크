local DashModule = {}

function DashModule.stringToKeyCode(str)
    if typeof(str) ~= "string" then return nil end
    str = string.upper(string.gsub(str, "%s+", ""))
    return Enum.KeyCode[str]
end

function DashModule.updateDashKey(str)
    local kc = DashModule.stringToKeyCode(str)
    if kc then
        Settings.Dash.key, Settings.Dash.keyString = kc, str
    end
end

function DashModule.setupCharacter(char)
    local hum = char:WaitForChild("Humanoid")
    local hrp = char:WaitForChild("HumanoidRootPart")
    Settings.Dash.canUse = true
    hum.Died:Connect(function()
        Settings.Dash.canUse = true
    end)
    return hum, hrp
end

if LocalPlayer.Character then
    DashModule.setupCharacter(LocalPlayer.Character)
end

LocalPlayer.CharacterAdded:Connect(DashModule.setupCharacter)

function DashModule.playDashSound(hrp)
    if not hrp then return end
    local sound = Instance.new("Sound", hrp)
    sound.SoundId = Settings.Dash.soundId
    sound.Volume = 1
    sound.PlaybackSpeed = 1
    sound:Play()
    Services.Debris:AddItem(sound, 2)
end

function DashModule.createDashEffect(hrp, duration)
    task.spawn(function()
        local startTime = os.clock()
        while os.clock() - startTime < duration do
            local effect = Instance.new("Part")
            effect.Size = Vector3.new(0.2, 0.2, math.random(2, 5))
            effect.Anchored = true
            effect.CanCollide = false
            effect.Material = Enum.Material.Neon
            effect.Color = Color3.fromRGB(220, 240, 255)
            effect.Transparency = 0.4
            
            -- 캐릭터 주변 무작위 위치
            local offset = Vector3.new(math.random(-2, 2), math.random(-1, 3), math.random(-2, 2))
            effect.CFrame = hrp.CFrame * CFrame.new(offset) * CFrame.Angles(0, 0, math.random(0, 360))
            effect.Parent = workspace
            
            local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
            local goal = {
                Size = effect.Size + Vector3.new(0, 0, 4),
                Transparency = 1,
                CFrame = effect.CFrame * CFrame.new(0, 0, 2)
            }
            
            local tween = Services.TweenService:Create(effect, tweenInfo, goal)
            tween:Play()
            Services.Debris:AddItem(effect, 0.3)
            
            task.wait(0.02)
        end
    end)
end

function DashModule.dashUpForward()
    if not Settings.Dash.enabled or not Settings.Dash.canUse then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hum, hrp = char:FindFirstChild("Humanoid"), char:FindFirstChild("HumanoidRootPart")
    if not hum or hum.Health <= 0 or not hrp then return end

    Settings.Dash.canUse = false
    DashModule.playDashSound(hrp)
    
    -- [QoL] 파츠 이펙트 효과 적용
    DashModule.createDashEffect(hrp, Settings.Dash.duration)

    local angleRad = math.rad(Settings.Dash.angleDeg)
    local tiltedCF = hrp.CFrame * CFrame.Angles(angleRad, 0, 0)
    local direction = tiltedCF.LookVector

    local att = Instance.new("Attachment", hrp)
    local lv = Instance.new("LinearVelocity", hrp)
    lv.Attachment0 = att
    lv.RelativeTo = Enum.ActuatorRelativeTo.World
    lv.MaxForce = math.huge
    lv.VectorVelocity = direction * Settings.Dash.force

