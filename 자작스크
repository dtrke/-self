local PlayerLockModule = {}

function PlayerLockModule.getClosestPlayer()
    local target, dist = nil, math.huge
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = myChar.HumanoidRootPart.Position
    
    for _, p in pairs(Services.Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") then
            if p.Character.Humanoid.Health > 0 then
                local d = (myPos - p.Character.HumanoidRootPart.Position).Magnitude
                if d < dist then
                    dist, target = d, p.Character.HumanoidRootPart
                end
            end
        end
    end
    return target
end

function PlayerLockModule.isTargetValid(tRoot)
    if not tRoot or not tRoot.Parent or not tRoot.Parent:FindFirstChild("Humanoid") then return false end
    return tRoot.Parent.Humanoid.Health > 0
end

function PlayerLockModule.isCharacterControlable()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if not hum then return false end
    local state = hum:GetState()
    if state == Enum.HumanoidStateType.Ragdoll or state == Enum.HumanoidStateType.FallingDown or 
       state == Enum.HumanoidStateType.Physics or state == Enum.HumanoidStateType.Dead or 
       state == Enum.HumanoidStateType.PlatformStanding then
        return false
    end
    return true
end

-- 플레이어 락 연결 변수
local PlayerLockConnection = nil

local function StartPlayerLock()
    if PlayerLockConnection then return end
    
    PlayerLockConnection = Services.RunService.RenderStepped:Connect(function()
        -- 레그돌 상태면 플레이어 락 중지
        if isRagdolled then
            if PlayerLockConnection then
                PlayerLockConnection:Disconnect()
                PlayerLockConnection = nil
            end
            Settings.PlayerLock.isActive = false
            Settings.PlayerLock.currentTarget = nil
            
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChild("Humanoid")
            if hum then
                hum.AutoRotate = true
            end
            return
        end
        

        
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        
        if not (root and hum) then return end
        if not PlayerLockModule.isCharacterControlable() then return end
        
        if not Settings.PlayerLock.isActive then
            hum.AutoRotate = true
            if PlayerLockConnection then
                PlayerLockConnection:Disconnect()
                PlayerLockConnection = nil
            end
            return
        end
        
        if not Settings.PlayerLock.currentTarget or not PlayerLockModule.isTargetValid(Settings.PlayerLock.currentTarget) then
            Settings.PlayerLock.isActive = false
            Settings.PlayerLock.currentTarget = nil
            hum.AutoRotate = true
            if PlayerLockConnection then
                PlayerLockConnection:Disconnect()
                PlayerLockConnection = nil
            end
            return
        end
        
        hum.AutoRotate = false
        local myPos, tPos = root.Position, Settings.PlayerLock.currentTarget.Position
        if not Settings.PlayerLock.includeY then
            tPos = Vector3.new(tPos.X, myPos.Y, tPos.Z)
        end
        root.CFrame = CFrame.new(myPos, tPos) * CFrame.Angles(0, math.rad(Settings.PlayerLock.offset), 0)
    end)
end

local function StopPlayerLock()
    if PlayerLockConnection then
        PlayerLockConnection:Disconnect()
        PlayerLockConnection = nil
    end
    
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum then
        hum.AutoRotate = true
    end
end

Services.UserInputService.InputBegan:Connect(function(io, p)
    if not p and io.KeyCode.Name == Settings.PlayerLock.lockKey then
        -- 레그돌 상태면 무시
        if isRagdolled then
            return
        end
        

        
        if Settings.PlayerLock.enabled then
            Settings.PlayerLock.isActive = not Settings.PlayerLock.isActive
            
            if Settings.PlayerLock.isActive then
                Settings.PlayerLock.currentTarget = PlayerLockModule.getClosestPlayer()
                if Settings.PlayerLock.currentTarget then
                    StartPlayerLock()
                else
                    Settings.PlayerLock.isActive = false
                end
            else
                StopPlayerLock()
            end
        end
    end
end)

