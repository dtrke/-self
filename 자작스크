local AimModule = {}

function AimModule.getScreenCenter()
    return Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
end

function AimModule.getAimPart(char)
    if Settings.Aim.headAim and char:FindFirstChild("Head") then
        return char.Head
    end
    return char:FindFirstChild("HumanoidRootPart")
end

function AimModule.isTargetValid(plr)
    if not plr or not plr.Character then return false end
    local hum = plr.Character:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if Settings.Aim.teamCheck and plr.Team == LocalPlayer.Team then return false end
    if Settings.Aim.excludedTeam and plr.Team and plr.Team.Name == Settings.Aim.excludedTeam then return false end
    return true
end

function AimModule.isCurrentTargetAlive()
    if not Settings.Aim.currentTarget or not Settings.Aim.currentTarget.Character then return false end
    local hum = Settings.Aim.currentTarget.Character:FindFirstChild("Humanoid")
    return hum and hum.Health > 0
end

function AimModule.getClosestPlayer2D()
    local closest, shortest = nil, math.huge
    local center = AimModule.getScreenCenter()
    
    for _, p in ipairs(Services.Players:GetPlayers()) do
        if p ~= LocalPlayer and AimModule.isTargetValid(p) then
            local part = AimModule.getAimPart(p.Character)
            if part then
                local pos, on = Camera:WorldToViewportPoint(part.Position)
                if on then
                    local screenDist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    local worldDist = (part.Position - Camera.CFrame.Position).Magnitude
                    
                    -- 점수 계산: 화면 거리(2D)와 월드 거리(3D) 가중치 합산 (낮을수록 우선순위 높음)
                    -- 월드 거리가 늘어날수록 화면 거리 점수에 페널티를 부여하여 가까운 적을 선호하도록 함
                    local score = screenDist * (1 + (worldDist / 120)) -- 120 studs 기준 가중치 부여
                    
                    if score < shortest then
                        shortest, closest = score, p
                    end
                end
            end
        end
    end
    return closest
end

