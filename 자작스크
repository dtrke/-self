local function RestoreAvatarChanger(character)
    if not character then return end
    ClearAvatarChangerConns()

    -- 1. 커스텀 악세서리 및 CharacterMesh 제거
    for _, obj in ipairs(character:GetChildren()) do
        if (obj:IsA("Accessory") or obj:IsA("CharacterMesh")) and obj:GetAttribute("IsCustomAvatar") then
            obj:Destroy()
        end
    end

    -- 2. 기존 악세서리 투명화 해제
    for _, obj in ipairs(character:GetChildren()) do
        if obj:IsA("Accessory") then
            local handle = obj:FindFirstChild("Handle")
            if handle and handle:IsA("BasePart") then
                handle.Transparency = 0
            end
        end
    end

    -- 3. 저장했던 원본 상태로 복구
    local backup = Settings.AvatarChanger.persistentBackup
    if backup then
        local bc = character:FindFirstChildOfClass("BodyColors")
        if bc and backup.BodyColors then
            bc.HeadColor3 = backup.BodyColors.HeadColor3
            bc.LeftArmColor3 = backup.BodyColors.LeftArmColor3
            bc.RightArmColor3 = backup.BodyColors.RightArmColor3
            bc.LeftLegColor3 = backup.BodyColors.LeftLegColor3
            bc.RightLegColor3 = backup.BodyColors.RightLegColor3
            bc.TorsoColor3 = backup.BodyColors.TorsoColor3
        end
        
        local p = character:FindFirstChildOfClass("Pants")
        if p then p.PantsTemplate = backup.Pants or "" end
        local s = character:FindFirstChildOfClass("Shirt")
        if s then s.ShirtTemplate = backup.Shirt or "" end

        -- CharacterMesh 복구 (기존 메쉬 모두 제거 후 백업본 생성)
        for _, obj in ipairs(character:GetChildren()) do
            if obj:IsA("CharacterMesh") then obj:Destroy() end
        end
        if backup.CharacterMeshes then
            for _, meshData in ipairs(backup.CharacterMeshes) do
                local cm = Instance.new("CharacterMesh")
                cm.MeshId = meshData.MeshId
                cm.BodyPart = meshData.BodyPart
                cm.BaseTextureId = meshData.BaseTextureId
                cm.OverlayTextureId = meshData.OverlayTextureId
                cm.Name = meshData.Name
                cm.Parent = character
            end
        end

        -- HeadMesh 복구 (기존 인스턴스 속성 복구)
        local head = character:FindFirstChild("Head")
        if head and backup.HeadMeshes then
            for _, obj in ipairs(head:GetChildren()) do
                if obj:IsA("SpecialMesh") or obj:IsA("Mesh") then
                    for _, meshData in ipairs(backup.HeadMeshes) do
                        if meshData.Name == obj.Name and meshData.ClassName == obj.ClassName then
                            if meshData.MeshId ~= nil then pcall(function() obj.MeshId = meshData.MeshId end) end
                            if meshData.TextureId ~= nil then pcall(function() obj.TextureId = meshData.TextureId end) end
                            if meshData.Scale ~= nil then pcall(function() obj.Scale = meshData.Scale end) end
                            if meshData.VertexColor ~= nil then pcall(function() obj.VertexColor = meshData.VertexColor end) end
                            if meshData.Offset ~= nil then pcall(function() obj.Offset = meshData.Offset end) end
                            if meshData.MeshType ~= nil then pcall(function() obj.MeshType = meshData.MeshType end) end
                            break
                        end
                    end
                end
            end
        end

        -- Face 디칼 복구 (숨김 해제)
        if head then
            for _, obj in ipairs(head:GetChildren()) do
                if obj:IsA("Decal") or obj.Name == "face" then
                    obj.Transparency = 0
                    if backup.FaceTexture then
                        obj.Texture = backup.FaceTexture
                    end
                end
            end
        end
    end
end


local function ApplyAvatarChanger(character, pattern)
    if not character or not character.Parent then return end
    if not Settings.AvatarChanger.enabled then return end
    
    local data = AVATAR_DATABASE[pattern:lower()]
    if not data then
        RestoreAvatarChanger(character)
        return
    end

    ClearAvatarChangerConns()

    -- 기존 CharacterMesh 제거 (이미 백업된 상태)
    for _, obj in ipairs(character:GetChildren()) do
        if obj:IsA("CharacterMesh") then
            obj:Destroy()
        end
    end

    -- 1. 기존 악세서리 투명화
    for _, obj in ipairs(character:GetChildren()) do
        if obj:IsA("Accessory") and not obj:GetAttribute("IsCustomAvatar") then
            local handle = obj:FindFirstChild("Handle")
            if handle and handle:IsA("BasePart") then
                handle.Transparency = 1
            end
        end
    end

    -- 2. 바디 컬러 적용
    local bodyColors = character:FindFirstChildOfClass("BodyColors") or Instance.new("BodyColors", character)
    if data.BodyColors then
        bodyColors.HeadColor3 = data.BodyColors.HeadColor
        bodyColors.LeftArmColor3 = data.BodyColors.LeftArmColor
        bodyColors.RightArmColor3 = data.BodyColors.RightArmColor
        bodyColors.LeftLegColor3 = data.BodyColors.LeftLegColor
        bodyColors.RightLegColor3 = data.BodyColors.RightLegColor
        bodyColors.TorsoColor3 = data.BodyColors.TorsoColor
    end

    -- 3. 옷 적용
    local pants = character:FindFirstChildOfClass("Pants") or Instance.new("Pants", character)
    pants.PantsTemplate = data.Pants or ""

    local shirt = character:FindFirstChildOfClass("Shirt") or Instance.new("Shirt", character)
    shirt.ShirtTemplate = data.Shirt or ""

    -- 4. 머리 메시 적용 및 기존 얼굴(Face) 삭제/숨김
    local head = character:FindFirstChild("Head")
    if head then
        if data.HeadMesh then
            for _, obj in ipairs(head:GetChildren()) do
                if obj:IsA("SpecialMesh") or obj:IsA("Mesh") then
                    obj.TextureId = ""
                    obj.MeshId = data.HeadMesh
                end
            end
        end
        -- 무조건 face (기본 얼굴) 디칼 안 보이게 처리 (삭제와 동일한 효과)
        for _, obj in ipairs(head:GetChildren()) do
            if obj:IsA("Decal") or obj.Name == "face" then
                obj.Texture = ""
                obj.Transparency = 1
            end
        end
    end

    -- 5. 커스텀 악세서리 추가
    if data.Accessories then
        for _, accData in ipairs(data.Accessories) do
            local target = getAttachmentPart(character, accData.part)
            if target then
                local existing = character:FindFirstChild(accData.name)
                if not (existing and existing:GetAttribute("IsCustomAvatar")) then
                    local acc = Instance.new("Accessory")
                    acc.Name = accData.name
                    acc:SetAttribute("IsCustomAvatar", true)
                    acc.Parent = character
                    
                    local handle = Instance.new("Part")
                    handle.Name = "Handle"
                    handle.Size = Vector3.new(1, 1, 1)
                    handle.CanCollide, handle.Anchored, handle.Massless = false, false, true
                    
                    local mesh = Instance.new("SpecialMesh")
                    mesh.MeshId = accData.meshId
                    mesh.TextureId = accData.textureId
                    if accData.scale then mesh.Scale = accData.scale end
                    mesh.Parent = handle
                    
                    local weld = Instance.new("Weld")
                    weld.Name = "AccessoryWeld"
                    weld.Part0, weld.Part1 = handle, target
                    weld.C0, weld.C1 = accData.c0, accData.c1
                    weld.Parent = handle
                    
                    handle.Parent = acc
                end
            end
        end
    end

    -- 6. 커스텀 CharacterMesh 추가
    if data.CharacterMeshes then
        for _, cmData in ipairs(data.CharacterMeshes) do
            local cm = Instance.new("CharacterMesh")
            cm.MeshId = cmData.MeshId
            cm.BodyPart = cmData.BodyPart
            cm.BaseTextureId = cmData.BaseTextureId
            cm.OverlayTextureId = cmData.OverlayTextureId
            cm.Name = cmData.Name or "CharacterMesh"
            cm:SetAttribute("IsCustomAvatar", true)
            if cmData.Attributes then
                for k, v in pairs(cmData.Attributes) do
                    cm:SetAttribute(k, v)
                end
            end
            cm.Parent = character
        end
    end

    -- 로블록스 초기화 버그 극복을 위한 적용 확인 마커
    character:SetAttribute("CustomAvatarLoaded_Mark", true)

    -- [신규 기능] 아바타 상태 유지 (투명화, 색상, 옷, 메쉬 고정) 및 변경된 원본 상태 기억
    local backup = Settings.AvatarChanger.persistentBackup

    local function applyBodyColors(bc)
        if not data.BodyColors then return end
        if bc.HeadColor3 ~= data.BodyColors.HeadColor then
            if backup and backup.BodyColors then backup.BodyColors.HeadColor3 = bc.HeadColor3 end
            bc.HeadColor3 = data.BodyColors.HeadColor 
        end
        if bc.LeftArmColor3 ~= data.BodyColors.LeftArmColor then 
            if backup and backup.BodyColors then backup.BodyColors.LeftArmColor3 = bc.LeftArmColor3 end
            bc.LeftArmColor3 = data.BodyColors.LeftArmColor 
        end
        if bc.RightArmColor3 ~= data.BodyColors.RightArmColor then 
            if backup and backup.BodyColors then backup.BodyColors.RightArmColor3 = bc.RightArmColor3 end
            bc.RightArmColor3 = data.BodyColors.RightArmColor 
        end
        if bc.LeftLegColor3 ~= data.BodyColors.LeftLegColor then 
            if backup and backup.BodyColors then backup.BodyColors.LeftLegColor3 = bc.LeftLegColor3 end
            bc.LeftLegColor3 = data.BodyColors.LeftLegColor 
        end
        if bc.RightLegColor3 ~= data.BodyColors.RightLegColor then 
            if backup and backup.BodyColors then backup.BodyColors.RightLegColor3 = bc.RightLegColor3 end
            bc.RightLegColor3 = data.BodyColors.RightLegColor 
        end
        if bc.TorsoColor3 ~= data.BodyColors.TorsoColor then 
            if backup and backup.BodyColors then backup.BodyColors.TorsoColor3 = bc.TorsoColor3 end
            bc.TorsoColor3 = data.BodyColors.TorsoColor 
        end
    end

    local function applyClothes()
        local pants = character:FindFirstChildOfClass("Pants")
        if pants and data.Pants and pants.PantsTemplate ~= data.Pants then 
            if backup then backup.Pants = pants.PantsTemplate end
            pants.PantsTemplate = data.Pants 
        end
        local shirt = character:FindFirstChildOfClass("Shirt")
        if shirt and data.Shirt and shirt.ShirtTemplate ~= data.Shirt then 
            if backup then backup.Shirt = shirt.ShirtTemplate end
            shirt.ShirtTemplate = data.Shirt 
        end
    end

    local function recordExternalCharacterMesh(obj)
        if backup and backup.CharacterMeshes then
            local replaced = false
            for i, meshData in ipairs(backup.CharacterMeshes) do
                if meshData.BodyPart == obj.BodyPart then
                    backup.CharacterMeshes[i] = {
                        MeshId = obj.MeshId,
                        BodyPart = obj.BodyPart,
                        BaseTextureId = obj.BaseTextureId,
                        OverlayTextureId = obj.OverlayTextureId,
                        Name = obj.Name
                    }
                    replaced = true
                    break
                end
            end
            if not replaced then
                table.insert(backup.CharacterMeshes, {
                    MeshId = obj.MeshId,
                    BodyPart = obj.BodyPart,
                    BaseTextureId = obj.BaseTextureId,
                    OverlayTextureId = obj.OverlayTextureId,
                    Name = obj.Name
                })
            end
        end
    end

    local function enforceCustomMeshes()
        if not data.CharacterMeshes then return end
        for _, obj in ipairs(character:GetChildren()) do
            if obj:IsA("CharacterMesh") and not obj:GetAttribute("IsCustomAvatar") then
                recordExternalCharacterMesh(obj)
                obj:Destroy()
            end
        end
        for _, cmData in ipairs(data.CharacterMeshes) do
            local found = false
            for _, obj in ipairs(character:GetChildren()) do
                if obj:IsA("CharacterMesh") and obj:GetAttribute("IsCustomAvatar") and obj.MeshId == cmData.MeshId then
                    found = true
                    break
                end
            end
            if not found then
                local cm = Instance.new("CharacterMesh")
                cm.MeshId = cmData.MeshId
                cm.BodyPart = cmData.BodyPart
                cm.BaseTextureId = cmData.BaseTextureId
                cm.OverlayTextureId = cmData.OverlayTextureId
                cm.Name = cmData.Name or "CharacterMesh"
                cm:SetAttribute("IsCustomAvatar", true)
                if cmData.Attributes then
                    for k, v in pairs(cmData.Attributes) do cm:SetAttribute(k, v) end
                end
                cm.Parent = character
            end
        end
    end

    table.insert(AvatarChangerConns, character.ChildAdded:Connect(function(obj)
        if obj:IsA("Accessory") and not obj:GetAttribute("IsCustomAvatar") then
            -- 새로 생긴 악세서리 즉시 투명화 (원래 존재하므로 끄면 0으로 복원됨)
            task.defer(function()
                local handle = obj:WaitForChild("Handle", 1)
                if handle and handle:IsA("BasePart") then handle.Transparency = 1 end
            end)
        elseif obj:IsA("BodyColors") then
            if backup then
                backup.BodyColors = {
                    HeadColor3 = obj.HeadColor3, LeftArmColor3 = obj.LeftArmColor3,
                    RightArmColor3 = obj.RightArmColor3, LeftLegColor3 = obj.LeftLegColor3,
                    RightLegColor3 = obj.RightLegColor3, TorsoColor3 = obj.TorsoColor3
                }
            end
            task.defer(function()
                applyBodyColors(obj)
                table.insert(AvatarChangerConns, obj.Changed:Connect(function() applyBodyColors(obj) end))
            end)
        elseif obj:IsA("Pants") then
            if backup then backup.Pants = obj.PantsTemplate end
            task.defer(function()
                applyClothes()
                table.insert(AvatarChangerConns, obj.Changed:Connect(applyClothes))
            end)
        elseif obj:IsA("Shirt") then
            if backup then backup.Shirt = obj.ShirtTemplate end
            task.defer(function()
                applyClothes()
                table.insert(AvatarChangerConns, obj.Changed:Connect(applyClothes))
            end)
        elseif obj:IsA("CharacterMesh") then
            if not obj:GetAttribute("IsCustomAvatar") then recordExternalCharacterMesh(obj) end
            task.defer(enforceCustomMeshes)
        end
    end))

    table.insert(AvatarChangerConns, character.ChildRemoved:Connect(function(obj)
        if obj:IsA("CharacterMesh") and obj:GetAttribute("IsCustomAvatar") then
            task.defer(enforceCustomMeshes)
        end
    end))

    -- 기존 객체들의 속성 변경 감지
    local existingBc = character:FindFirstChildOfClass("BodyColors")
    if existingBc then table.insert(AvatarChangerConns, existingBc.Changed:Connect(function() applyBodyColors(existingBc) end)) end
    
    local existingPants = character:FindFirstChildOfClass("Pants")
    if existingPants then table.insert(AvatarChangerConns, existingPants.Changed:Connect(applyClothes)) end
    
    local existingShirt = character:FindFirstChildOfClass("Shirt")
    if existingShirt then table.insert(AvatarChangerConns, existingShirt.Changed:Connect(applyClothes)) end
end


