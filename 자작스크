local ESPModule = {}

function ESPModule.getHPColor(hp, maxHp)
    if maxHp <= 0 then return Color3.new(0,0,0) end
    local ratio = math.clamp(hp / maxHp, 0, 1)
    if ratio <= 0 then return Color3.new(0, 0, 0) end
    if ratio >= 0.75 then return Settings.ESP.textColor end
    local t = ratio / 0.75
    return Color3.new(1, t, t)
end

function ESPModule.getTeamColor(plr)
    if plr.Team and plr.Team.TeamColor then
        return plr.Team.TeamColor.Color
    end
    return Settings.ESP.outlineColor
end

function ESPModule.getTorso(char)
    if not char or not char:IsA("Model") then return nil end
    return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") or char:FindFirstChild("HumanoidRootPart")
end

function ESPModule.create(plr)
    if not Settings.ESP.enabled or not plr or plr == LocalPlayer then return end
    if ESP_FOLDER:FindFirstChild("ESP_" .. plr.Name) then return end

    local gui = Instance.new("BillboardGui")
    gui.Name = "ESP_" .. plr.Name
    gui.AlwaysOnTop = true
    gui.Size = UDim2.new(0, 320, 0, 120)
    gui.MaxDistance = math.huge
    gui.LightInfluence = 0
    gui.Parent = ESP_FOLDER

    local image = Instance.new("ImageLabel")
    image.Size = UDim2.new(0, 110, 0, 110)
    image.AnchorPoint = Vector2.new(0.5, 0.5)
    image.Position = UDim2.new(0.5, 0, 0.5, 0)
    image.BackgroundTransparency = 1
    image.Image = "rbxassetid://" .. Settings.ESP.imageAssetId
    image.ScaleType = Enum.ScaleType.Fit
    image.Parent = gui

    local info = Instance.new("TextLabel")
    info.BackgroundTransparency = 1
    info.Font = Enum.Font.SourceSansBold
    info.TextStrokeTransparency = 0
    info.TextSize = 16
    info.TextXAlignment = Enum.TextXAlignment.Left
    info.TextYAlignment = Enum.TextYAlignment.Top
    info.AnchorPoint = Vector2.new(0, 0.5)
    info.Position = UDim2.new(0.5, 65, 0.5, -5)
    info.Size = UDim2.new(0, 200, 0, 100)
    info.TextWrapped = true
    info.Text = plr.Name -- [FIX] 생성 즉시 이름 표시하여 "Label" 노출 방지
    info.Parent = gui

    local torso, humanoid, highlight
    local timeElapsed, rotation, targetRotation = 0, 0, 0
    local highlightName = "ESP_Highlight_" .. plr.Name

    local function createHighlight(char)
        local existing = ESP_FOLDER:FindFirstChild(highlightName)
        if existing then existing:Destroy() end
        
        local h = Instance.new("Highlight")
        h.Name = highlightName
        h.Adornee = char
        h.FillTransparency = 1
        h.OutlineTransparency = 0
        h.OutlineColor = ESPModule.getTeamColor(plr)
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.Parent = ESP_FOLDER
        highlight = h
    end

    local function updateCharacter()
        local char = plr.Character
        if not char then return end
        torso = ESPModule.getTorso(char)
        humanoid = char:FindFirstChildOfClass("Humanoid")
        if torso then gui.Adornee = torso end
        createHighlight(char)
    end

    updateCharacter()
    
    local charAddedConn = plr.CharacterAdded:Connect(function()
        task.wait(0.3)
        if Settings.ESP.enabled then updateCharacter() end
    end)
    
    local charRemovingConn = plr.CharacterRemoving:Connect(function()
        gui.Adornee = nil
        if highlight then highlight:Destroy() highlight = nil end
    end)
    
    local teamChangedConn = plr:GetPropertyChangedSignal("Team"):Connect(function()
        if highlight then highlight.OutlineColor = ESPModule.getTeamColor(plr) end
    end)

    task.spawn(function()
        while gui.Parent do
            local dt = Services.RunService.Heartbeat:Wait()
            local char = plr.Character
            local isReady = char and torso and torso.Parent == char and humanoid and humanoid.Parent == char
            
            if not Settings.ESP.enabled or not isReady then
                gui.Enabled = false
                if highlight then highlight.Enabled = false end
                if not torso or not torso.Parent then updateCharacter() end
                continue
            end
            
            gui.Enabled = true
            if highlight then highlight.Enabled = true end
            timeElapsed += dt
            
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local distance = hrp and (torso.Position - hrp.Position).Magnitude or math.huge
            local rotationSpeed = math.clamp(100 / (distance + 0.1), 0.25, 5)
            targetRotation -= rotationSpeed
            rotation += (targetRotation - rotation) * 0.125

            image.Visible = Settings.ESP.showImage
            image.Rotation = rotation % 360
            local scale = 1 + 0.2 * ((math.sin(timeElapsed * 0.6) + 1) / 2)
            image.Size = UDim2.new(0, 110 * scale, 0, 110 * scale)

            info.Text = string.format("%s\nHP: %d/%d\n거리: %d", plr.Name, math.floor(humanoid.Health), math.floor(humanoid.MaxHealth), math.floor(distance))
            info.TextColor3 = ESPModule.getHPColor(humanoid.Health, humanoid.MaxHealth)
        end
        
        charAddedConn:Disconnect()
        charRemovingConn:Disconnect()
        teamChangedConn:Disconnect()
        gui:Destroy()
        if highlight then highlight:Destroy() end
    end)
end

function ESPModule.refresh()
    for _, v in pairs(ESP_FOLDER:GetChildren()) do v:Destroy() end
    if Settings.ESP.enabled then
        for _, plr in pairs(Services.Players:GetPlayers()) do
            if plr ~= LocalPlayer then ESPModule.create(plr) end
        end
    end
end

