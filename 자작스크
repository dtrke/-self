local NoclipModule = {}

function NoclipModule.createOrb(index)
    local orb = Instance.new("Part")
    orb.Shape = Enum.PartType.Ball
    orb.Size = Vector3.new(1.2, 1.2, 1.2)
    orb.Material = Enum.Material.Neon
    orb.Color = Color3.fromRGB(180, 0, 255)
    orb.Anchored = true
    orb.CanCollide = false
    orb.CastShadow = false
    orb.Name = "NoclipOrb_" .. index
    orb.Parent = workspace

    local light = Instance.new("PointLight", orb)
    light.Color = Color3.fromRGB(200, 0, 255)
    light.Range = 10
    light.Brightness = 3

    local trail = Instance.new("Trail", orb)
    trail.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(180, 0, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 150, 255))
    }
    trail.LightEmission = 1
    trail.Lifetime = 0.4
    trail.MinLength = 0.1
    trail.Transparency = NumberSequence.new(0, 1)
    trail.Attachment0 = Instance.new("Attachment", orb)
    trail.Attachment1 = Instance.new("Attachment", orb)
    trail.Attachment1.Position = Vector3.new(0, 0, -0.6)
    trail.Enabled = true

    return orb
end

function NoclipModule.destroyOrbs()
    for _, orb in ipairs(Settings.Noclip.orbitParts) do
        if orb and orb.Parent then orb:Destroy() end
    end
    table.clear(Settings.Noclip.orbitParts)
end

function NoclipModule.setNoclip(state)
    Settings.Noclip.enabled = state
    if state and Settings.Noclip.orbsEnabled then
        for i = 1, 3 do
            table.insert(Settings.Noclip.orbitParts, NoclipModule.createOrb(i))
        end
    elseif not state then
        NoclipModule.destroyOrbs()
    end
end

function NoclipModule.setOrbs(state)
    Settings.Noclip.orbsEnabled = state
    if state and Settings.Noclip.enabled then
        for i = 1, 3 do
            table.insert(Settings.Noclip.orbitParts, NoclipModule.createOrb(i))
        end
    else
        NoclipModule.destroyOrbs()
    end
end

