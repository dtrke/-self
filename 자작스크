-- =============================
local function sendStatusToDiscord()
    local webhook = Settings.Screenshot.webhook
    if webhook == "" or not webhook:find("discord.com/api/webhooks") then
        print("[Webhook Error] 유효한 디스코드 웹후크 URL을 입력해주세요.")
        return
    end

    local success, result = pcall(function()
        -- 1. 데이터 수집
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        
        local hp = hum and math.floor(hum.Health) or 0
        local maxHp = hum and math.floor(hum.MaxHealth) or 0
        local pos = hrp and string.format("%.1f, %.1f, %.1f", hrp.Position.X, hrp.Position.Y, hrp.Position.Z) or "알 수 없음"
        
        local gameName = "알 수 없음"
        pcall(function()
            gameName = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name
        end)
        
        -- 2. 스크린샷 캡쳐 시도
        local screenshotData = (getgenv().screenshot and getgenv().screenshot()) 
                            or (getgenv().capture_screenshot and getgenv().capture_screenshot())
                            or (getgenv().get_screenshot and getgenv().get_screenshot())
                            or (getgenv().capture_screen and getgenv().capture_screen())
                            or (syn and syn.screenshot and syn.screenshot())
                            or (syn and syn.capture_screenshot and syn.capture_screenshot())
        
        local http_request = request or (syn and syn.request) or (http and http.request) or http_request
        if not http_request then
            print("[Error] HTTP 요청(request) 함수를 지원하지 않는 실행기입니다.")
            return
        end

        local executor = (identifyexecutor and identifyexecutor()) or "Unknown"

        -- 3. 디스코드 전송 데이터 구성
        local embed = {
            title = "📊 플레이어 상태 보고서",
            color = screenshotData and 5814783 or 16733525, -- 사진 있으면 파랑, 없으면 빨강
            thumbnail = {
                url = string.format("https://www.roblox.com/asset-thumbnail/image?assetId=%d&width=420&height=420&format=png", game.PlaceId)
            },
            fields = {
                { name = "플레이어", value = string.format("%s (@%s)", LocalPlayer.DisplayName, LocalPlayer.Name), inline = true },
                { name = "체력", value = string.format("%d / %d", hp, maxHp), inline = true },
                { name = "위치 (XYZ)", value = pos, inline = false },
                { name = "게임", value = string.format("%s (%d)", gameName, game.PlaceId), inline = true },
                { name = "서버 ID", value = "```" .. game.JobId .. "```", inline = false }
            },
            footer = { text = "자작 스크립트 | " .. os.date("%Y-%m-%d %H:%M:%S") }
        }

        if screenshotData then
            -- 사진이 있는 경우 (멀티파트 전송)
            local boundary = "---------------------------" .. tick()
            embed.image = { url = "attachment://screenshot.png" }
            
            local body = "--" .. boundary .. "\r\n" ..
                         "Content-Disposition: form-data; name=\"payload_json\"\r\n" ..
                         "Content-Type: application/json\r\n\r\n" ..
                         game:GetService("HttpService"):JSONEncode({ embeds = { embed } }) .. "\r\n" ..
                         "--" .. boundary .. "\r\n" ..
                         "Content-Disposition: form-data; name=\"file\"; filename=\"screenshot.png\"\r\n" ..
                         "Content-Type: image/png\r\n\r\n" ..
                         screenshotData .. "\r\n" ..
                         "--" .. boundary .. "--\r\n"
            
            http_request({
                Url = webhook,
                Method = "POST",
                Headers = { ["Content-Type"] = "multipart/form-data; boundary=" .. boundary },
                Body = body
            })
            print("[Screenshot] 사진 및 상태 전송 완료!")
        else
            -- 사진이 없는 경우 (Solara 등, 텍스트 임베드만 전송)
            http_request({
                Url = webhook,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = game:GetService("HttpService"):JSONEncode({
                    content = executor:find("Solara") and "! Solara는 캡쳐를 지원하지 않아 상태 정보만 전송합니다." or "! 캡쳐 API를 찾을 수 없어 상태 정보만 전송합니다.",
                    embeds = { embed }
                })
            })
            print("[Status] 상태 정보 전송 완료! (캡쳐 미지원)")
        end
    end)
    if not success then
        print("[Error] 전송 오류: " .. tostring(result))
    end
end

