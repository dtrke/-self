-- 현재 플레이중인 사운드 감지
local function GetCurrentPlayingSound()
    if getgenv and getgenv().FunnyMusicPlaying and getgenv().CurrentFunnyMusic and getgenv().CurrentFunnyMusic ~= "" then
        local funnySound = game:GetService("CoreGui"):FindFirstChild(getgenv().CurrentFunnyMusic)
        if funnySound and funnySound:IsA("Sound") and funnySound.IsPlaying and funnySound.TimeLength > 0 then
            return funnySound
        end
    end
    return nil
end

local VisualizerTime = 0
local lastCamLook = Camera.CFrame.LookVector
local lastCamPos = Camera.CFrame.Position -- 캐릭터 움직임 감지를 위한 위치 추적 추가
local currentSway = Vector2.new(0, 0)

-- 비주얼라이저 및 타임라인 실시간 렌더링
Services.RunService.RenderStepped:Connect(function(dt)
    local sound = GetCurrentPlayingSound()
    
    -- 카메라/캐릭터 움직임 물리 효과 (현실적인 스웨이)
    local currentLook = Camera.CFrame.LookVector
    local currentPos = Camera.CFrame.Position
    
    local lookDelta = currentLook - lastCamLook
    -- 카메라 로컬 좌표계 기준으로 위치 변화량 산출 (이동 방향 감지)
    local posDelta = Camera.CFrame:VectorToObjectSpace(currentPos - lastCamPos)
    
    lastCamLook = currentLook
    lastCamPos = currentPos
    
    -- 회전(관성)과 이동(가속도 느낌)을 결합하여 타겟 스웨이 계산
    -- 화면 회전에 따른 감도를 3배 낮춤 (20 -> 6.6)
    
    -- [보정] 3인칭 줌 아웃 시 위치 변화량이 과하게 커지는 현상 방지
    local camDistance = (currentPos - Camera.Focus.Position).Magnitude
    local posDamping = math.max(1, camDistance / 10) -- 거리가 멀수록 이동 감도 감쇄
    
    local targetSway = Vector2.new(
        (lookDelta.X * 6.6) - (posDelta.X * 1.5 / posDamping), 
        (lookDelta.Y * 6.6) + (posDelta.Y * 1.5 / posDamping)
    )
    
    -- 타임라인이 화면 밖으로 너무 크게 벗어나는 것 방지 (Cap)
    targetSway = Vector2.new(math.clamp(targetSway.X, -0.3, 0.3), math.clamp(targetSway.Y, -0.3, 0.3))
    
    currentSway = currentSway:Lerp(targetSway, 0.1)
    currentSway = currentSway * 0.92 -- 감쇠(관성 유지)
    
    local swayX, swayY = currentSway.X * 100, currentSway.Y * 100
    
    -- 비주얼라이저 바는 고정 (스웨이 제거)
    leftContainer.Position = UDim2.new(0, 0, 0.5, 0)
    rightContainer.Position = UDim2.new(1, 0, 0.5, 0)
    
    -- 타임라인 바에만 위치 상향(0.85) 및 스웨이 오프셋 적용
    -- [NEW] 사운드 크기에 따른 타임라인 떨림(Shake) 계산 (과하지 않게 normalized 기반 jitter 적용)
    local timelineShakeX, timelineShakeY = 0, 0
    if sound and sound.IsPlaying then
        local loudness = sound.PlaybackLoudness or 0
        -- [EXPONENTIAL SHAKE] 작은 소리에는 둔감하게, 큰 소리에는 폭발적으로 반응 (상한 15.0)
        -- (loudness/500)의 제곱을 사용하여 낮은 볼륨에서의 떨림을 억제합니다.
        local factor = loudness / 500
        local shakeIntensity = 0.1 + (math.pow(factor, 2) * 14.9) 
        timelineShakeX = math.random(-100, 100) / 100 * shakeIntensity
        timelineShakeY = math.random(-100, 100) / 100 * shakeIntensity
    end
    
    timelineBox.Position = UDim2.new(0.5, swayX + timelineShakeX, 0.78, swayY + timelineShakeY)
    
    -- [NEW] 소리 크기에 따른 타임라인 크기 동적 스케일링 (Pulse Effect)
    -- normalized 변수가 아래에서 선언되므로, 여기서 직접 참조하거나 아래에서 처리
    if sound and sound.IsPlaying then
        local loudness = sound.PlaybackLoudness or 0
        local pulseNormalized = math.clamp(loudness / 500, 0, 1)
        local sizeScale = 1 + (pulseNormalized * 0.12) -- 최대 12% 확대
        timelineBox.Size = UDim2.new(0.4 * sizeScale, 0, 0.015 * sizeScale, 0)
    else
        timelineBox.Size = UDim2.new(0.4, 0, 0.015, 0)
    end

    if sound and sound.IsPlaying then
        MusicVisualizer.Gui.Enabled = true
        
        -- 드래그 중이 아닐 때만 사운드 진행도에 따라 타임라인 업데이트
        if not isDraggingTimeline then
            local progress = math.clamp(sound.TimePosition / sound.TimeLength, 0, 1)
            timelineProgress.Size = UDim2.new(progress, 0, 1, 0)
        end
        
        local loudness = sound.PlaybackLoudness or 0
        local normalized = math.clamp(loudness / 500, 0.05, 1)
        
        -- [RESTORED] 비주얼라이저 흐름 속도는 원래대로 복구 (0.5 ~ 3.0)
        local speedMultiplier = 0.5 + (normalized * 2.5)
        VisualizerTime = VisualizerTime + (dt * speedMultiplier)
        
        for i = 1, numBars do
            local factor = (i - 1) / (numBars - 1) 
            local wave = math.sin((VisualizerTime * 15) - (i * 0.3)) * 0.05
            
            -- 비주얼라이저 반응 폭 조정
            local targetScale = math.clamp(normalized * (0.55 - factor * 0.25) + wave, 0.01, 1)
            
            local curL = leftBars[i].Size.X.Scale
            local newL = curL + (targetScale - curL) * 0.25
            leftBars[i].Size = UDim2.new(newL, 0, leftBars[i].Size.Y.Scale, 0)
            
            local curR = rightBars[i].Size.X.Scale
            local newR = curR + (targetScale - curR) * 0.25
            rightBars[i].Size = UDim2.new(newR, 0, rightBars[i].Size.Y.Scale, 0)
            
            -- [전체 흑백 테마] 비주얼라이저 바
            -- 색 간격을 1.25배 더 촘촘하게 조정 (5.0 -> 6.25) 및 검은색 영역 확대
            local grayVal = math.clamp(0.4 + 0.7 * math.cos(VisualizerTime * 2 - (i/numBars) * 6.25), 0, 1)
            local dynamicColor = Color3.new(grayVal, grayVal, grayVal)
            
            leftBars[i].BackgroundColor3 = dynamicColor
            rightBars[i].BackgroundColor3 = dynamicColor
        end
        -- 타임라인 색상도 일관성 있게 흑백으로 공유
        timelineProgress.BackgroundColor3 = leftBars[1].BackgroundColor3
    else
        MusicVisualizer.Gui.Enabled = false
    end
end)
