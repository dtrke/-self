local function SmoothMouseMoveToAbsolute(targetAbsolutePosition, duration)
    local uis = game:GetService("UserInputService")
    local startPos = uis:GetMouseLocation()
    local totalDelta = targetAbsolutePosition - startPos
    local startTime = tick()
    local conn
    local lastAlpha = 0
    
    conn = game:GetService("RunService").RenderStepped:Connect(function()
        local elapsed = tick() - startTime
        if elapsed >= duration then
            local remainingAlpha = 1 - lastAlpha
            if remainingAlpha > 0 and mousemoverel then
                local finalMove = totalDelta * remainingAlpha
                mousemoverel(finalMove.X, finalMove.Y)
            end
            if conn then conn:Disconnect() end
            return
        end
        local alpha = elapsed / duration
        local easeAlpha = -(math.cos(math.pi * alpha) - 1) / 2
        
        local moveAlpha = easeAlpha - lastAlpha
        lastAlpha = easeAlpha
        
        local stepDelta = totalDelta * moveAlpha
        if mousemoverel then
            mousemoverel(stepDelta.X, stepDelta.Y)
        end
    end)
    task.wait(duration)
end

local function performAutoWaveSequence()
    if not Settings.SGR.autoWaveEnabled then return end

    if isRejoinSequencePending then
        isRejoinSequencePending = false
        if Settings.SGR.reconnectEnabled then
            task.spawn(function()
            task.wait(25)
            if not Settings.SGR.autoWaveEnabled then return end

            local vim = game:GetService("VirtualInputManager")
            local guiService = game:GetService("GuiService")
            local inset, _ = guiService:GetGuiInset()
            local topBarOffset = Vector2.new(0, inset.Y)
            
            -- [NEW] 스크립트 UI의 TitleBar ImageButton 클릭
            local coreGui = game:GetService("CoreGui")
            local hiddenUI = coreGui:FindFirstChild("HiddenUI")
            local scriptUI = hiddenUI and hiddenUI:FindFirstChild("자작 스크립트 🧊  ~  ▣ ABSOLUTE ▣ ✨")
            local titleBarBtn = scriptUI and scriptUI:FindFirstChild("MainFrame", true) and scriptUI.MainFrame:FindFirstChild("TitleBar", true) and scriptUI.MainFrame.TitleBar:FindFirstChild("ImageButton", true)
            
            if titleBarBtn and titleBarBtn:IsA("GuiButton") then
                local center = titleBarBtn.AbsolutePosition + (titleBarBtn.AbsoluteSize / 2) + topBarOffset
                SmoothMouseMoveToAbsolute(center, 0.5)
                task.wait(0.5)
                vim:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 1)
                task.wait(0.05)
                vim:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 1)
                task.wait(1)
            end

            local playerGui = LocalPlayer:WaitForChild("PlayerGui", 10)
            local titleGui = playerGui and playerGui:FindFirstChild("Title[WIP]")
            local startBtn = titleGui and titleGui:FindFirstChild("IntroCard", true) and titleGui.IntroCard:FindFirstChild("Start", true) and titleGui.IntroCard.Start:FindFirstChild("Button", true)

