Services.RunService.RenderStepped:Connect(function()
    if isRagdolled then 
        -- print("Aim Bottled: Ragdoll status blocking.")
        return 
    end
    
    if (Settings.PlayerLock.enabled and Settings.PlayerLock.isActive) or 
       (Settings.CharLock.masterToggle and Settings.CharLock.isLocked) then
        return
    end
    
    if Settings.Aim.enabled then
        if not AimModule.isCurrentTargetAlive() then
            -- print("Aim Debug: No alive target.")
            return
        end
        
        local targetChar = Settings.Aim.currentTarget.Character
        local part = AimModule.getAimPart(targetChar)
        if part then
            local predictedPos = part.Position
            if Settings.Aim.predictionEnabled then
                predictedPos = predictedPos + (part.AssemblyLinearVelocity * (Settings.Aim.predictionMs / 1000))
            end

            if Settings.Aim.forced then
                local screenPos, onScreen = Camera:WorldToScreenPoint(predictedPos)
                if onScreen then
                    local mousePos = Services.UserInputService:GetMouseLocation()
                    local sens = Settings.Aim.forcedSensitivity or 0.5
                    local moveX = (screenPos.X - mousePos.X) * sens
                    local moveY = (screenPos.Y - mousePos.Y) * sens
                    
                    local finalX = math.round(moveX)
                    local finalY = math.round(moveY)

                    if mousemoverel then
                        mousemoverel(finalX, finalY)
                    elseif Services.VirtualInputManager then
                        Services.VirtualInputManager:SendMouseMoveEvent(mousePos.X + finalX, mousePos.Y + finalY, workspace)
                    else
                        -- print("Aim Debug: No mouse movement function available!")
                    end
                else
                    -- print("Aim Debug: Target off-screen.")
                end
            else
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, predictedPos)
            end
        end
    end
end)

