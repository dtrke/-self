        if hum then
            UIElements.LastHealth = hum.Health
            if (hum.Health / hum.MaxHealth) <= 0.3 then
                UIElements.hasPulsed70 = true
            else
                UIElements.hasPulsed70 = false
            end
        else
            UIElements.LastHealth = nil
            UIElements.hasPulsed70 = false
        end
    end

    local char = Settings.Aim.currentTarget.Character
    local hum = char:FindFirstChild("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    local camDelta = UIElements.lastCamCF:ToObjectSpace(Camera.CFrame)
    local targetOffset = Vector2.new(-camDelta.X * 260, -camDelta.Y * 260)
    UIElements.camOffset = UIElements.camOffset:Lerp(targetOffset, 0.1)
    UIElements.camOffset = Vector2.new(
        math.clamp(UIElements.camOffset.X, -80, 80),
        math.clamp(UIElements.camOffset.Y, -80, 80)
    )
    UIElements.lastCamCF = Camera.CFrame

    UIElements.displayName.Text = Settings.Aim.currentTarget.DisplayName
    UIElements.userName.Text = "(@" .. Settings.Aim.currentTarget.Name .. ")"

    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local dist = myRoot and (root.Position - myRoot.Position).Magnitude or (root.Position - Camera.CFrame.Position).Magnitude
    
    -- 벽 감지 (Raycast)
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {myChar, char}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    
    local aimPart = AimModule.getAimPart(char) or root
    local rayDirection = (aimPart.Position - Camera.CFrame.Position)
    local rayResult = workspace:Raycast(Camera.CFrame.Position, rayDirection, rayParams)

    -- [OPTIMIZED] 타겟 발광(Highlight) 즉시 처리
    if not UIElements.isDeathAnimating then
        if rayResult then
            UIElements.targetHighlight.FillColor = Color3.fromRGB(173, 216, 230)
            UIElements.targetHighlight.OutlineColor = Color3.fromRGB(173, 216, 230)
        else
            UIElements.targetHighlight.FillColor = Color3.fromRGB(255, 255, 255)
            UIElements.targetHighlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        end
        UIElements.targetHighlight.Adornee = char
        UIElements.targetHighlight.Enabled = true
    end

    local hp, max = hum.Health, hum.MaxHealth
    local percent = math.clamp(hp / max, 0, 1)

    UIElements.hpNumber.Text = string.format("%.0f / %.0f", hp, max)
    UIElements.hpBar.Size = UDim2.new(percent,0,1,0)

    local baseColor = Color3.new(1,1,1)
    if percent <= 0.5 then
        local t = (0.5 - percent) / 0.5
        baseColor = baseColor:Lerp(Color3.fromRGB(255,50,50), t)
    end

    -- [자잘한 파동]: HP가 30% 이하일 때 생기는 효과 (원샷킬 시에는 뜨지 않음)
    if not UIElements.isInstantKill and percent <= 0.3 then
        if not UIElements.hasPulsed70 then
            -- [강력한 파동]: HP가 30% 이하로 처음 내려갔을 때
            -- 한 번에 죽더라도 원샷킬이 아니면 애니메이션 동안 파동이 뜨게 함
            UIElements.hasPulsed70 = true
            UIElements.lastPulseTime = tick()
            PulseHUD(false) -- 강력한 펄스
        else
            -- 자잘한 파동 지속 루프
            local dynamicInterval = 0.1 + (percent / 0.3) * 0.9
            if tick() - UIElements.lastPulseTime >= dynamicInterval then
                UIElements.lastPulseTime = tick()
                PulseHUD(true) -- 자잘한 펄스
            end
        end
    end

    if UIElements.LastHealth then
        local delta = UIElements.LastHealth - hp
        if delta > 0 then
            local loss = delta / max
            UIElements.ShakePower = math.clamp(loss * 240, 20, 240)
            UIElements.BarShake = math.clamp(loss * 60, 8, 40)
            UIElements.FlashAlpha = math.clamp(loss * 4, 0.4, 1.5)

            -- [강력한 파동]: 피가 한번에 50%이상 닳았을 때 (원샷킬 중이 아니며 죽지 않았을 때만)
            if hp > 0 and loss >= 0.5 and not UIElements.isInstantKill then
                UIElements.ShakePower = 1000
                UIElements.BarShake = 100
                UIElements.FlashAlpha = 3
                PulseHUD(false) -- 강력한 파동 발생
            end
        end
    end
    UIElements.LastHealth = hp

    if UIElements.FlashAlpha > 0 then
        local flashColor = percent <= 0.3 and Color3.fromRGB(255,0,0) or Color3.new(1,1,1) -- 30% 이하 시 진한 빨간색
        baseColor = baseColor:Lerp(flashColor, math.clamp(UIElements.FlashAlpha,0,1))
    end
    
    -- 원샷킬 중이면 보라색 유지, 아니면 계산된 baseColor 적용
    UIElements.hpBar.BackgroundColor3 = UIElements.isInstantKill and Color3.fromRGB(180, 0, 255) or baseColor

    -- [QoL] 원샷킬 진동 유지시간 보정 (0.3~0.4초 유지되도록 감쇄율 조정)
    local decayShake = UIElements.isInstantKill and 0.94 or 0.88
    local decayBar = UIElements.isInstantKill and 0.92 or 0.85
    local decayFlash = UIElements.isInstantKill and 0.90 or 0.82

    UIElements.ShakePower *= decayShake
    UIElements.BarShake *= decayBar
    UIElements.FlashAlpha *= decayFlash

    local shakeX = math.random(-UIElements.BarShake, UIElements.BarShake)
    local shakeY = math.random(-UIElements.BarShake, UIElements.BarShake)

    if percent <= 0.3 then
        -- HP가 낮을수록 진동 강도 증가
        local baseIntensity = 1.5 -- 기존 3에서 2배 낮춤
        local dynamicIntensity = (0.3 - percent) * 25 -- 감도 대폭 하향
        local intensity = baseIntensity + dynamicIntensity
        
        shakeX = shakeX + math.random(-intensity, intensity)
        shakeY = shakeY + math.random(-intensity, intensity)
    end

    if not UIElements.isDeathAnimating then
        if rayResult then
            -- 벽 뒤에 있을 때 문구 표시
            UIElements.distText.Text = string.format("거리 %.1f <font color=\"rgb(173, 216, 230)\">[ 벽 뒤 ]</font>", dist)
        else
            -- 직접 보일 때 문구 표시
            UIElements.distText.Text = string.format("거리 %.1f", dist)
        end
        UIElements.distText.TextColor3 = Color3.fromRGB(200,200,200)
    end

    
    UIElements.hpBar.Position = UDim2.new(0, shakeX, 0, shakeY)

    -- [REFINED] UI 진동: ShakePower를 직접 사용하여 5배 더 강력하게 표현
    local uiShakeX = math.random(-UIElements.ShakePower, UIElements.ShakePower)
    local uiShakeY = math.random(-UIElements.ShakePower, UIElements.ShakePower)

    UIElements.rightFrame.Position = UDim2.new(0.5, 300 + 115 - 60 - 55 + uiShakeX + UIElements.camOffset.X + UIElements.enterValue.Value * 900, 0.62, UIElements.camOffset.Y + uiShakeY)
    UIElements.leftFrame.Position = UDim2.new(0.5, -300 - 560 + 60 + 55 + UIElements.camOffset.X * 0.6 - UIElements.enterValue.Value * 900, 0.62, UIElements.camOffset.Y * 0.6)
    
    UIElements.teamText.Text = Settings.Aim.currentTarget.Team and Settings.Aim.currentTarget.Team.Name or "[ 소속 없음 ]"
    UIElements.teamText.TextColor3 = Settings.Aim.currentTarget.Team and Settings.Aim.currentTarget.Team.TeamColor.Color or Color3.fromRGB(180,180,180)

    -- [장애물 삭제] 로직 실행
    if Settings.Aim.clearObstacles then
        local aimPart = AimModule.getAimPart(char) or root
        ObstacleManager.clearObstaclesToTarget(aimPart)
    else
        ObstacleManager.restoreAll()
    end
end)

-- 에임 실제 적용 (레그돌 체크 추가됨)
Services.RunService.RenderStepped:Connect(function()
    -- 레그돌 상태면 무시
    if isRagdolled then
        return
    end
    

    
    -- 플레이어 락이나 캐릭터 락이 활성화되어 있으면 무시
    if (Settings.PlayerLock.enabled and Settings.PlayerLock.isActive) or 
       (Settings.CharLock.masterToggle and Settings.CharLock.isLocked) then
        return
    end
    
    if Settings.Aim.enabled and AimModule.isCurrentTargetAlive() then
        local targetChar = Settings.Aim.currentTarget.Character
        local part = AimModule.getAimPart(targetChar)
        if part then
            local predictedPos = part.Position
            
            if Settings.Aim.predictionEnabled then
                local velocity = part.AssemblyLinearVelocity
                predictedPos = predictedPos + (velocity * (Settings.Aim.predictionMs / 1000))
            end

            if Settings.Aim.forced and mousemoverel then
                local currentLook = Camera.CFrame.LookVector
                local targetLook = (predictedPos - Camera.CFrame.Position).Unit
                
                -- Calculate angles
                local dotX = currentLook:Dot(targetLook)
                local currentRight = Camera.CFrame.RightVector
                local currentUp = Camera.CFrame.UpVector
                
                local deltaX = currentRight:Dot(targetLook)
                local deltaY = currentUp:Dot(targetLook)
                
                -- Convert to pixel movement based on FOV and ViewportSize
                local viewportSize = Camera.ViewportSize
                local fovRatio = math.tan(math.rad(Camera.FieldOfView / 2))
                
                -- The sensitivity multiplier ensures it doesn't snap instantly
                local sens = Settings.Aim.forcedSensitivity
                local moveX = (deltaX / fovRatio) * (viewportSize.X / 2) * sens
                local moveY = -(deltaY / fovRatio) * (viewportSize.X / 2) * sens

                mousemoverel(moveX, moveY)
            else
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, predictedPos)
            end
        end
    end
end)

