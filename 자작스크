-- 1. 처음 스크립트를 켰을 때, 익스플로잇 workspace 폴더에 '링크 파일' 자동 생성 (이미 있으면 생성 안함)
local function UpdatePersistence()
    if writefile and isfile then
        if Settings.Persistence.enabled then
            if not isfile("ZajakScript_Loader.lua") then
                local loaderCode = 'loadstring(game:HttpGet("' .. myScriptUrl .. '"))()'
                writefile("ZajakScript_Loader.lua", loaderCode)
            end
        else
            if isfile("ZajakScript_Loader.lua") then
                pcall(function() delfile("ZajakScript_Loader.lua") end)
            end
        end
    end
    
    if queue_on_teleport then
        if not Settings.Persistence.enabled then
            pcall(function() queue_on_teleport("") end)
        end
    end
end

-- 초기 실행 시 퍼시스턴스 업데이트
