    SGR_Logic.isBrimRunning = true

    local newChar = character
    
    if isInitial then
        -- 1. [FIX] 초기 실행 시에만 재설정
        task.wait(1)
        if not Settings.SGR.autoBrimstoneEnabled then SGR_Logic.isBrimRunning = false return end
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then hum.Health = 0 end
        
