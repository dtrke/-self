local function pressSpaceOnce()
	if Services.VirtualInputManager then
		Services.VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
		task.wait(0.05)
		Services.VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
		return true
	end
	local char = LocalPlayer.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if hum then hum.Jump = true return true end
	return false
end

local function pressEOnTarget(target)
	local prompt = getPrompt(target)
	if prompt and typeof(fireproximityprompt) == "function" then
		pcall(function() fireproximityprompt(prompt) end)
		return true
	end
	if Services.VirtualInputManager then
		for i = 1, 2 do
			Services.VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
			task.wait(0.2)
			Services.VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
			if i < 2 then task.wait(0.08) end
		end
		return true
	end
	return false
end

local function updateMovementState(lastPos, stillSince, jumpUsedThisStall, jumpOriginPos)
	local char = LocalPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root then return nil, nil, jumpUsedThisStall, jumpOriginPos, false, false end
	local currentPos = root.Position
	if not lastPos then return currentPos, tick(), jumpUsedThisStall, nil, false, false end
	
	local movedSinceLast = (currentPos - lastPos).Magnitude
	
	-- 10스터드 이상 이동 시 점프 초기화
	if jumpUsedThisStall and jumpOriginPos then
		local distFromJump = (currentPos - jumpOriginPos).Magnitude
		if distFromJump >= 10 then
			jumpUsedThisStall = false
			jumpOriginPos = nil
		end
	end

	-- 움직임이 있으면 (1.5스터드 이상) 타이머 리셋
	if movedSinceLast >= STUCK_MOVE_THRESHOLD then 
		return currentPos, tick(), jumpUsedThisStall, jumpOriginPos, false, false 
	end

	local elapsed = tick() - stillSince
	local shouldJump = false
	if elapsed >= JUMP_STUCK_TIME and not jumpUsedThisStall then
		shouldJump = true
		jumpUsedThisStall = true
		jumpOriginPos = currentPos -- 점프한 위치 저장
	end
	
	if elapsed >= STUCK_TIME then 
		return currentPos, stillSince, jumpUsedThisStall, jumpOriginPos, shouldJump, true 
	end
	return lastPos, stillSince, jumpUsedThisStall, jumpOriginPos, shouldJump, false
end

local function captureInitialSoundSet(target)
	local initial = setmetatable({}, { __mode = "k" })
	for _, desc in ipairs(target:GetDescendants()) do
		if desc.Name == "Sound" then initial[desc] = true end
	end
	return initial
end

local function hasNewSound(target, initialSoundSet)
	if not target or not target.Parent then return false end
	for _, desc in ipairs(target:GetDescendants()) do
		if desc.Name == "Sound" and not initialSoundSet[desc] then return true end
	end
	return false
end

local function waitInRange(target, timeout)
	local deadline = tick() + timeout
	local lastPos, stillSince, jumpUsed, jumpOrg = nil, nil, false, nil
	while tick() < deadline do
		if not target or not target.Parent or not Settings.SolEgg.enabled then return false, "aborted" end
		local char = LocalPlayer.Character
		local root = char and char:FindFirstChild("HumanoidRootPart")
		local hum = char and char:FindFirstChild("Humanoid")
		local pos = getWorldPosition(target)
		if not root or not pos then return false, "missing reference" end
		local diff = root.Position - pos
		local horizontalDist = Vector2.new(diff.X, diff.Z).Magnitude
		local verticalDist = math.abs(diff.Y)
		
		Settings.SolEgg.distance = diff.Magnitude
		UpdateEggHUD()
		
		if horizontalDist <= INTERACT_DISTANCE and verticalDist <= 15 then 
			return true, "in range" 
		end
		
		-- [MOD] 직접 이동 로직 삭제 (외부 시스템 활용)
		-- hum:MoveTo(pos)
		
		local sj, stuck
		lastPos, stillSince, jumpUsed, jumpOrg, sj, stuck = updateMovementState(lastPos, stillSince, jumpUsed, jumpOrg)
		if sj then pressSpaceOnce() end
		if stuck then return false, "stuck" end
		task.wait(0.1)
	end
	return false, "timeout"
end

local function waitForSoundOrStuck(target, initialSet, duration)
	local deadline = tick() + duration
	local lastPos, stillSince, jumpUsed, jumpOrg = nil, nil, false, nil
	while tick() < deadline do
		if not target or not target.Parent or not Settings.SolEgg.enabled then return false, "aborted" end
		if hasNewSound(target, initialSet) then return true, "sound detected" end
		local sj, stuck
		lastPos, stillSince, jumpUsed, jumpOrg, sj, stuck = updateMovementState(lastPos, stillSince, jumpUsed, jumpOrg)
		if sj then pressSpaceOnce() end
		if stuck then return false, "stuck" end
		task.wait(0.05)
	end
	return false, "no sound"
end

local function attemptE(target, initialSet)
	for i = 1, 1 + EXTRA_E_RETRIES do
		if not target or not target.Parent or not Settings.SolEgg.enabled then return false, "aborted" end
		Settings.SolEgg.status = "E 입력 시도 (" .. i .. "/" .. (1 + EXTRA_E_RETRIES) .. ")"
		UpdateEggHUD()
		pressEOnTarget(target)
		local ok, reason = waitForSoundOrStuck(target, initialSet, E_RETRY_DELAY)
		if ok then return true, "success" end
		if reason == "stuck" or reason == "aborted" then return false, reason end
	end
	return false, "failed all E retries"
end

local function formatUptime()
    local seconds = math.floor(tick() - scriptStartTime)
    local days = math.floor(seconds / 86400)
    seconds = seconds % 86400
    local hours = math.floor(seconds / 3600)
    seconds = seconds % 3600
    local minutes = math.floor(seconds / 60)
    seconds = seconds % 60
    
    local parts = {}
    if days > 0 then table.insert(parts, days .. "일") end
    if hours > 0 then table.insert(parts, hours .. "시간") end
    if minutes > 0 then table.insert(parts, minutes .. "분") end
    table.insert(parts, seconds .. "초")
    
    return table.concat(parts, " ")
end

