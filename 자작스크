function SGR_Logic.WaveStandard()
    if SGR_Logic.isWaveStandardRunning or not Settings.SGR.autoWaveEnabled then return end
    SGR_Logic.isWaveStandardRunning = true
    
    local d_hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")

    if d_hum then
        -- 30초 이상 변화 없으면 리셋하는 루프 (별도 스폰)
        task.spawn(function()
            local lastPos = (LocalPlayer.Character and LocalPlayer.Character.PrimaryPart) and LocalPlayer.Character.PrimaryPart.Position or Vector3.zero
            local timeWithoutChange = 0
            while Settings.SGR.autoWaveEnabled and SGR_Logic.isWaveStandardRunning do
                task.wait(1)
                local char = LocalPlayer.Character
                if not char or not char.PrimaryPart then break end
                local currentPos = char.PrimaryPart.Position
                if (currentPos - lastPos).Magnitude < 1 then
                    timeWithoutChange = timeWithoutChange + 1
                else
                    lastPos = currentPos
                    timeWithoutChange = 0
                end
                
                if timeWithoutChange >= 30 then
                    local h = char:FindFirstChild("Humanoid")
                    if h then h.Health = 0 end -- 30초 경과 시 스스로 재설정
                    break
                end
            end
        end)
        
        -- [NEW] 7초에 1바퀴씩 회전하는 기능 (추가됨)
        task.spawn(function()
            local startTime = tick()
            while Settings.SGR.autoWaveEnabled and SGR_Logic.isWaveStandardRunning do
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local hum = char and char:FindFirstChild("Humanoid")
                
                -- [MODIFIED] 오토마우스가 켜져있고 살아있을 때만 회전
                if Settings.SGR.autoClickEnabled and hrp and hum and hum.Health > 0 then
                    local elapsed = tick() - startTime
                    -- 7초에 1바퀴 (360도)
                    local rotationAngle = (elapsed / 7) * 360
                    local currentCF = hrp.CFrame
                    -- 위치는 유지하고 회전만 변경
                    hrp.CFrame = CFrame.new(currentCF.Position) * CFrame.Angles(0, math.rad(rotationAngle % 360), 0)
                end
                task.wait()
            end
        end)
        
        -- 죽을 때까지 0.1초마다 현재 마우스 위치에 오토마우스(클릭)
        while Settings.SGR.autoWaveEnabled and SGR_Logic.isWaveStandardRunning do
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
            if not hum or hum.Health <= 0 then
                break -- 죽었으면 루프 탈출
            end
            
            local mouseLoc = game:GetService("UserInputService"):GetMouseLocation()
            local vim = game:GetService("VirtualInputManager")
            vim:SendMouseButtonEvent(mouseLoc.X, mouseLoc.Y, 0, true, game, 1)
            task.wait(0.05)
            vim:SendMouseButtonEvent(mouseLoc.X, mouseLoc.Y, 0, false, game, 1)
            task.wait(0.05)
        end
    end
    SGR_Logic.isWaveStandardRunning = false
end

local isWaveSequenceRunning = false
local function performAutoWaveSequence()
    if isWaveSequenceRunning or not Settings.SGR.autoWaveEnabled then return end
    isWaveSequenceRunning = true
    
    local function endSequence()
        isWaveSequenceRunning = false
    end
    
    local monitorThread
    local function cleanupAndEnd()
        if monitorThread then pcall(function() task.cancel(monitorThread) end) monitorThread = nil end
        endSequence()
    end

    if isRejoinSequencePending then
        isRejoinSequencePending = false
        if Settings.SGR.reconnectEnabled then
            task.spawn(function()
                -- [FIX] cleanupAndEnd()를 호출하여 상태를 정상적으로 초기화하도록 수정
            task.wait(25)
            if not Settings.SGR.autoWaveEnabled then cleanupAndEnd() return end

            local vim = game:GetService("VirtualInputManager")
            local guiService = game:GetService("GuiService")
            local inset, _ = guiService:GetGuiInset()
            local topBarOffset = Vector2.new(0, inset.Y)
            
            -- [NEW] 스크립트 UI의 TitleBar ImageButton 클릭
            local coreGui = game:GetService("CoreGui")
            local hiddenUI = coreGui:FindFirstChild("HiddenUI")
            local scriptUI = hiddenUI and hiddenUI:FindFirstChild("자작 스크립트 🧊  ~  ▣ ABSOLUTE ▣ ✨")
            local titleBarBtn = scriptUI and scriptUI:FindFirstChild("MainFrame", true) and scriptUI.MainFrame:FindFirstChild("TitleBar", true) and scriptUI.MainFrame.TitleBar:FindFirstChild("ImageButton", true)
            
            if titleBarBtn and titleBarBtn:IsA("GuiButton") then
                local center = titleBarBtn.AbsolutePosition + (titleBarBtn.AbsoluteSize / 2) + topBarOffset
                SmoothMouseMoveToAbsolute(center, 0.5)
                task.wait(0.5)
                vim:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 1)
                task.wait(0.05)
                vim:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 1)
                task.wait(1)
            end

            local playerGui = LocalPlayer:WaitForChild("PlayerGui", 10)
            local titleGui = playerGui and playerGui:FindFirstChild("Title[WIP]")
            local startBtn = titleGui and titleGui:FindFirstChild("IntroCard", true) and titleGui.IntroCard:FindFirstChild("Start", true) and titleGui.IntroCard.Start:FindFirstChild("Button", true)

            if startBtn and startBtn:IsA("GuiButton") then
                local center = startBtn.AbsolutePosition + (startBtn.AbsoluteSize / 2) + topBarOffset
                SmoothMouseMoveToAbsolute(center, 0.5)
                task.wait(0.5)
                vim:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 1)
                task.wait(0.05)
                vim:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 1)
                
                task.wait(10)
                if not Settings.SGR.autoWaveEnabled then cleanupAndEnd() return end

                vim:SendKeyEvent(true, Enum.KeyCode.O, false, game)
                task.wait(0.77) -- [MODIFIED] 1s -> 0.77s
                vim:SendKeyEvent(false, Enum.KeyCode.O, false, game)
                
                task.wait(1)
                local char = LocalPlayer.Character
                local hum = char and char:FindFirstChild("Humanoid")
                if hum then
                    hum.Health = 0
                end
                cleanupAndEnd() -- [FIX] 성공적으로 종료 시 호출
            else
                -- 버튼을 못 찾은 경우 시퀀스 종료 (재귀 호출 제거하여 무한 루프 방지)
                cleanupAndEnd()
            end
        end)
            return -- rejoin handles its own state
        end
    end
    
    -- [안전장치] 30초간 HP 변화 감지 및 강제 재설정(초기화) + 엔티티 감지
    monitorThread = task.spawn(function()
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local hum = char:WaitForChild("Humanoid", 3)
        if not hum then return end
        
        local lastHP = hum.Health
        local timeWithoutChange = 0
        local entityConn
        
        -- [NEW] 즉시 재설정을 위한 엔티티 감지 로직 (ChildAdded)
        local function checkEntity(child)
            if child.Name == "Plorb" or child.Name == "Chorber" then
                local currentHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
                if currentHum then currentHum.Health = 0 end
                return true
            end
            return false
        end

        local entities = workspace:FindFirstChild("Entities")
        if entities then
            -- 기존에 이미 있는 경우 체크
            for _, child in ipairs(entities:GetChildren()) do
                if checkEntity(child) then break end
            end
            -- 새로 생기는 경우 실시간 감지
            entityConn = entities.ChildAdded:Connect(function(child)
                checkEntity(child)
            end)
        end
        
        while Settings.SGR.autoWaveEnabled do
            task.wait(1)
            local currentHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
            if not currentHum or currentHum.Health <= 0 then
                break -- 죽으면 루프 종료, 다음 생에 새로 시작
            end
            
            if math.abs(currentHum.Health - lastHP) >= 1 then
                lastHP = currentHum.Health
                timeWithoutChange = 0 -- HP 변화가 있으면 타이머 리셋
            else
                timeWithoutChange = timeWithoutChange + 1
                if timeWithoutChange >= 30 then
                    currentHum.Health = 0 -- 30초 경과 시 스스로 재설정
                    break
                end
            end
        end
        
        if entityConn then entityConn:Disconnect() end
    end)
    
    task.wait(1)
    if not Settings.SGR.autoWaveEnabled then cleanupAndEnd() return end
    
    local vim = game:GetService("VirtualInputManager")
    
    -- 시작할 때 가장 먼저 좌측 쉬프트 누르기 (1회 입력)
    vim:SendKeyEvent(true, Enum.KeyCode.LeftShift, false, game)
    task.wait(0.05)
    vim:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
    task.wait(0.5)

    vim:SendKeyEvent(true, Enum.KeyCode.H, false, game)
    task.wait(0.5)
    vim:SendKeyEvent(false, Enum.KeyCode.H, false, game)
    task.wait(0.5)
    
    vim:SendKeyEvent(true, Enum.KeyCode.N, false, game)
    task.wait(0.5)
    vim:SendKeyEvent(false, Enum.KeyCode.N, false, game)
    task.wait(0.5)
    
    vim:SendKeyEvent(true, Enum.KeyCode.T, false, game)
    task.wait(0.5)
    vim:SendKeyEvent(false, Enum.KeyCode.T, false, game)
    
    task.wait(1)
    if not Settings.SGR.autoWaveEnabled then cleanupAndEnd() return end
    
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local minigames = workspace:FindFirstChild("Minigames")
    local terminal = minigames and minigames:FindFirstChild("Terminal")
    local targetDest = terminal and terminal:FindFirstChild("SmallScreen")
    
    if hum and targetDest and hum.Health > 0 then
        hum:MoveTo(targetDest.Position)
        hum.MoveToFinished:Wait()
    end
    
    task.wait(3)
    if not Settings.SGR.autoWaveEnabled then cleanupAndEnd() return end
    
    local gui = LocalPlayer.PlayerGui:FindFirstChild("bossSpawningGui")
    if gui then
        local rootFrame = gui:FindFirstChild("MainFrame") and gui.MainFrame:FindFirstChild("MainFrame")
        local bossBtn = rootFrame and rootFrame:FindFirstChild("Bosses") and rootFrame.Bosses:FindFirstChild("Wave Survival")
        
        if bossBtn then
            local center = bossBtn.AbsolutePosition + (bossBtn.AbsoluteSize / 2) + Vector2.new(0, 36)
            SmoothMouseMoveToAbsolute(center, 0.5) -- 최소 0.3초 이상 소모
            task.wait(1)
            vim:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 1)
            task.wait(0.05)
            vim:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 1)
        end
        
        task.wait(1)
        if not Settings.SGR.autoWaveEnabled then cleanupAndEnd() return end
        
        local summonBtn = rootFrame and rootFrame:FindFirstChild("Summon")
        if summonBtn then
            local center = summonBtn.AbsolutePosition + (summonBtn.AbsoluteSize / 2) + Vector2.new(0, 36)
            SmoothMouseMoveToAbsolute(center, 0.5)
            task.wait(1)
            vim:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 1)
            task.wait(0.05)
            vim:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 1)
            
            task.wait(1)
            if not Settings.SGR.autoWaveEnabled then cleanupAndEnd() return end
            
            -- SUMMON 클릭 성공 후 A키 5초 유지
            vim:SendKeyEvent(true, Enum.KeyCode.A, false, game)
            task.wait(5)
            vim:SendKeyEvent(false, Enum.KeyCode.A, false, game)
            
            -- 오토마우스 시작 시 보스 속박 자동 활성화
            if bossBindToggleObj and not Settings.SGR.bossBindEnabled then
                Settings.SGR.bossBindEnabled = true
                pcall(function() bossBindToggleObj:SetState(true) end)
            end
            
            -- [NEW] 소환 성공 후 전투 루프(클릭) 시작
            task.spawn(SGR_Logic.WaveStandard)
        end
    end
    cleanupAndEnd()
end





function SGR_Logic.BrimstoneProtocol(isInitial, character)
