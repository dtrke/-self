local AntiFlingModule = {}

function AntiFlingModule.trackPart(part)
    if not part or not part:IsA("BasePart") then return end
    if Settings.AntiFling.origCanCollide[part] == nil then
        Settings.AntiFling.origCanCollide[part] = part.CanCollide
    end
    part.CanCollide = false
end

function AntiFlingModule.restorePart(part)
    if Settings.AntiFling.origCanCollide[part] ~= nil then
        pcall(function()
            part.CanCollide = Settings.AntiFling.origCanCollide[part]
        end)
    end
end

function AntiFlingModule.disableForCharacter(char)
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("BasePart") then
            AntiFlingModule.trackPart(obj)
        end
    end
    if not Settings.AntiFling.charDescConns[char] then
        Settings.AntiFling.charDescConns[char] = char.DescendantAdded:Connect(function(desc)
            if Settings.AntiFling.enabled and desc:IsA("BasePart") then
                AntiFlingModule.trackPart(desc)
            end
        end)
    end
end

function AntiFlingModule.enable()
    if Settings.AntiFling.enabled then return end
    Settings.AntiFling.enabled = true
    
    for _, plr in ipairs(Services.Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            if plr.Character then
                AntiFlingModule.disableForCharacter(plr.Character)
            end
            Settings.AntiFling.playerCharConns[plr] = plr.CharacterAdded:Connect(AntiFlingModule.disableForCharacter)
        end
    end

    Settings.AntiFling.playersAddedConn = Services.Players.PlayerAdded:Connect(function(plr)
        if plr ~= LocalPlayer then
            Settings.AntiFling.playerCharConns[plr] = plr.CharacterAdded:Connect(AntiFlingModule.disableForCharacter)
        end
    end)

    Settings.AntiFling.enforceConn = Services.RunService.Stepped:Connect(function()
        if not Settings.AntiFling.enabled then return end
        for _, plr in ipairs(Services.Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                for _, part in ipairs(plr.Character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        AntiFlingModule.trackPart(part)
                    end
                end
            end
        end
    end)
end

function AntiFlingModule.disable()
    if not Settings.AntiFling.enabled then return end
    Settings.AntiFling.enabled = false
    
    if Settings.AntiFling.enforceConn then
        Settings.AntiFling.enforceConn:Disconnect()
        Settings.AntiFling.enforceConn = nil
    end
    
    if Settings.AntiFling.playersAddedConn then
        Settings.AntiFling.playersAddedConn:Disconnect()
        Settings.AntiFling.playersAddedConn = nil
    end
    
    for _, conn in pairs(Settings.AntiFling.playerCharConns) do
        conn:Disconnect()
    end
    Settings.AntiFling.playerCharConns = {}
    
    for _, conn in pairs(Settings.AntiFling.charDescConns) do
        conn:Disconnect()
    end
    Settings.AntiFling.charDescConns = {}
    
    for part in pairs(Settings.AntiFling.origCanCollide) do
        AntiFlingModule.restorePart(part)
    end
end

