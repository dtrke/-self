-- Egg Bot Core Helpers
local function nameHasEgg(name)
	return string.find(string.lower(name), "egg", 1, true) ~= nil
end

local function getTargetPart(obj)
	if obj:IsA("BasePart") then return obj end
	if obj:IsA("Model") then
		if obj.PrimaryPart then return obj.PrimaryPart end
		local hrp = obj:FindFirstChild("HumanoidRootPart")
		if hrp and hrp:IsA("BasePart") then return hrp end
		local anyPart = obj:FindFirstChildWhichIsA("BasePart")
		if anyPart then return anyPart end
	end
	return nil
end

local function getWorldPosition(obj)
	local part = getTargetPart(obj)
	return part and part.Position or nil
end

local function getPrompt(obj)
	if obj:IsA("ProximityPrompt") then return obj end
	return obj:FindFirstChildWhichIsA("ProximityPrompt", true)
end

local function isValidEggCandidate(obj)
	if not obj or not obj.Parent or obj.Parent ~= workspace then return false end
	if not (obj:IsA("Model") or obj:IsA("BasePart")) then return false end
	if not nameHasEgg(obj.Name) then return false end
	
	local exclusionTime = Settings.SolEgg.excludedTargets[obj]
	if exclusionTime then
		if type(exclusionTime) == "number" then
			if tick() - exclusionTime < 600 then
				return false
			end
		else
			-- 하위 호환성 및 불리언 처리
			return false
		end
	end
	
	return getWorldPosition(obj) ~= nil
end

local function moveCameraToTarget(targetPos)
	local oldType = Camera.CameraType
	local oldCFrame = Camera.CFrame
	Camera.CameraType = Enum.CameraType.Scriptable
	local lookPos = targetPos + Vector3.new(0, CAMERA_LOOK_HEIGHT, 0)
	local camPos = lookPos + Vector3.new(0, CAMERA_DISTANCE, 0)
	Camera.CFrame = CFrame.new(camPos) * CFrame.Angles(-math.rad(90), 0, 0)
	task.wait(0.05)
	return function()
		Camera.CameraType = oldType
		if oldType == Enum.CameraType.Scriptable then Camera.CFrame = oldCFrame end
	end
end

local function rightClickScreenCenter()
	if not Camera or not Services.VirtualInputManager then return false end
	local x, y = math.floor(Camera.ViewportSize.X / 2), math.floor(Camera.ViewportSize.Y / 2)
	Services.VirtualInputManager:SendMouseButtonEvent(x, y, 1, true, game, 0)
	task.wait(0.03)
	Services.VirtualInputManager:SendMouseButtonEvent(x, y, 1, false, game, 0)
	return true
end

local function leftDoubleClickScreenCenter()
	if not Camera or not Services.VirtualInputManager then return false end
	local x, y = math.floor(Camera.ViewportSize.X / 2), math.floor(Camera.ViewportSize.Y / 2)
	for i = 1, 2 do
		Services.VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
		task.wait(0.03)
		Services.VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
		if i < 2 then task.wait(0.08) end
	end
