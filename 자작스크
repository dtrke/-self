local TPModule = {}

function TPModule.getNearestPlayer()
    local nearestPlayer, shortestDistance = nil, math.huge
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position

    for _, player in pairs(Services.Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (player.Character.HumanoidRootPart.Position - myPos).Magnitude
            if dist < shortestDistance then
                shortestDistance, nearestPlayer = dist, player
            end
        end
    end
    return nearestPlayer
end

function TPModule.createBlock(position, size, color, lookAt)
    local part = Instance.new("Part")
    part.Size = size
    part.Anchored = true
    part.CanCollide = false
    part.Material = Enum.Material.Neon
    part.Color = color
    part.CFrame = lookAt and CFrame.new(position, lookAt) or CFrame.new(position)
    part.Parent = workspace
    return part
end

function TPModule.createDashedLine(startPos, endPos, spacing, size, color)
    local distance = (endPos - startPos).Magnitude
    if distance < spacing then return {} end
    local steps = math.max(1, math.floor(distance / spacing + 0.5))
    local parts = {}
    for i = 1, steps do
        local t = i / (steps + 1)
        table.insert(parts, TPModule.createBlock(startPos:Lerp(endPos, t), size, color))
    end
    return parts
end

function TPModule.fadeOutPart(part, targetCFrame, duration)
    if not part then return end
    local goals = {Transparency = 1}
    if targetCFrame then goals.CFrame = targetCFrame end
    Services.TweenService:Create(part, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), goals):Play()
    Services.Debris:AddItem(part, duration)
end

function TPModule.createDynamicRedRing(center, duration)
    if Settings.Teleport.effectLevel < 5 then return end
    local parts = {}
    for i = 1, 20 do
        local angle = math.rad(i * 18)
        local part = TPModule.createBlock(center + Vector3.new(math.cos(angle)*2, math.sin(angle)*2, 0), Vector3.new(0.2,0.2,0.2), Color3.fromRGB(255,0,0))
        table.insert(parts, {part=part, angle=angle, speed=math.random()*5+5})
    end

    local startTime = tick()
    local conn
    conn = Services.RunService.Heartbeat:Connect(function()
        local elapsed = tick() - startTime
        if elapsed > duration then
            conn:Disconnect()
            for _, p in ipairs(parts) do p.part:Destroy() end
            return
        end
        local shrinkFactor = 1 - (elapsed/duration)*0.9
        for _, p in ipairs(parts) do
            local shake = Vector3.new((math.random()-0.5)*0.15, (math.random()-0.5)*0.15, (math.random()-0.5)*0.15)
            p.angle = p.angle + math.rad(p.speed)
            p.part.Position = center + Vector3.new(math.cos(p.angle)*2*shrinkFactor, math.sin(p.angle)*2*shrinkFactor, 0) + shake
        end
    end)
end

function TPModule.explodeRedPartGrand(redPart)
    if Settings.Teleport.effectLevel < 5 or not redPart then
        if redPart then redPart:Destroy() end
        return
    end
    local pos = redPart.Position
    redPart:Destroy()
    for i = 1, 37 do
        local part = TPModule.createBlock(pos, Vector3.new(0.2+math.random()*0.3, 0.2+math.random()*0.3, 0.2+math.random()*0.3), Color3.fromRGB(255,0,0))
        local dir = Vector3.new(math.random()-0.5, math.random()-0.5, math.random()-0.5).Unit * ((2 + math.random()*5)*2)
        Services.TweenService:Create(part, TweenInfo.new(0.5 + math.random()*0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame = part.CFrame + dir, Transparency = 1}):Play()
        Services.Debris:AddItem(part, 0.8 + math.random()*0.2)
    end
end

function TPModule.spawnBlueSpark(pos, duration)
    if Settings.Teleport.effectLevel < 5 then return end
    local startTime = tick()
    local conn
    conn = Services.RunService.Heartbeat:Connect(function()
        if tick() - startTime > duration then
            conn:Disconnect()
            return
        end
        if math.random() < 0.5 then return end
        local offset = Vector3.new((math.random()-0.5)*2, (math.random()-0.5)*2, (math.random()-0.5)*2)
        local spark = TPModule.createBlock(pos + offset, Vector3.new(0.2,0.2,0.2), Color3.fromRGB(100,100,255))
        local dir = Vector3.new(math.random()-0.5, math.random()-0.5, math.random()-0.5) * 0.25
        Services.TweenService:Create(spark, TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {CFrame = spark.CFrame + dir, Transparency = 1}):Play()
        Services.Debris:AddItem(spark, 1)
    end)
end

function TPModule.spawnTeleportExplosion(pos)
    if Settings.Teleport.effectLevel < 5 then return end
    for i = 1, 30 do
        local spark = TPModule.createBlock(pos, Vector3.new(0.3 + math.random()*0.4, 0.3 + math.random()*0.4, 0.3 + math.random()*0.4), Color3.fromRGB(100,100,255))
        local dir = Vector3.new(math.random()-0.5, math.random()-0.5, math.random()-0.5).Unit * (4.5 + math.random()*2)
        Services.TweenService:Create(spark, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame = spark.CFrame + dir, Transparency = 1}):Play()
        Services.Debris:AddItem(spark, 1)
    end
end

function TPModule.teleportBehindNearestPlayer()
    local targetPlayer = nil
    
    targetPlayer = TPModule.getNearestPlayer()
    
    if not targetPlayer then return end
    local targetChar, myChar = targetPlayer.Character, LocalPlayer.Character
    if not targetChar or not myChar then return end

    local targetRoot, myRoot = targetChar:FindFirstChild("HumanoidRootPart"), myChar:FindFirstChild("HumanoidRootPart")
    if not targetRoot or not myRoot then return end

    local oldPos = myRoot.Position
    local behindPos = targetRoot.Position - (targetRoot.CFrame.LookVector * Settings.Teleport.distance)

    if Settings.Teleport.effectLevel == 1 then
        myRoot.CFrame = CFrame.new(behindPos, targetRoot.Position)
        return
    end

    local blueStart, blueEnd
    if Settings.Teleport.effectLevel >= 2 then
        blueStart = TPModule.createBlock(oldPos, Vector3.new(1,1,1), Color3.fromRGB(100,100,255))
        blueEnd = TPModule.createBlock(behindPos, Vector3.new(1,1,1), Color3.fromRGB(100,100,255))
        if Settings.Teleport.effectLevel == 5 then
            TPModule.spawnBlueSpark(oldPos, 3)
            TPModule.spawnBlueSpark(behindPos, 3)
        end
    end

    local whiteParts = {}
    if Settings.Teleport.effectLevel >= 3 then
        whiteParts = TPModule.createDashedLine(oldPos, behindPos, 5, Vector3.new(0.3,0.3,0.3), Color3.fromRGB(255,255,255))
    end

    local redParts = {}
    if Settings.Teleport.effectLevel >= 4 then
        redParts = TPModule.createDashedLine(oldPos, behindPos, 30, Vector3.new(0.7,0.7,0.7), Color3.fromRGB(255,0,0))
    end

    if Settings.Teleport.effectLevel == 5 then
        for _, part in ipairs(redParts) do
            TPModule.createDynamicRedRing(part.Position, 4)
        end
    end

    myRoot.CFrame = CFrame.new(behindPos, targetRoot.Position)

    if Settings.Teleport.effectLevel == 5 then
        TPModule.spawnTeleportExplosion(behindPos)
    end
    
    if Settings.Teleport.effectLevel >= 2 then
        task.delay(3, function()
            TPModule.fadeOutPart(blueStart, nil, 1.5)
            TPModule.fadeOutPart(blueEnd, nil, 1.5)
        end)
    end
    
    if Settings.Teleport.effectLevel >= 3 then
        task.delay(1.5, function()
            for _, part in ipairs(whiteParts) do
                TPModule.fadeOutPart(part, nil, 0.3)
            end
        end)
    end
    
    if Settings.Teleport.effectLevel == 4 then
        task.delay(3, function()
            for _, part in ipairs(redParts) do
                TPModule.fadeOutPart(part,nil,0.3)
            end
            for _, part in ipairs(whiteParts) do
                TPModule.fadeOutPart(part,nil,0.3)
            end
        end)
    end
    
    if Settings.Teleport.effectLevel == 5 then
        task.delay(4, function()
            for _, part in ipairs(redParts) do
                TPModule.explodeRedPartGrand(part)
            end
        end)
    end
end

Services.UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Settings.Teleport.key and Settings.Teleport.enabled then
        TPModule.teleportBehindNearestPlayer()
    end
end)

