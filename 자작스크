        task.wait(1)
        if not Settings.SGR.autoWaveEnabled then return end
        
        local summonBtn = rootFrame and rootFrame:FindFirstChild("Summon")
        if summonBtn then
            local center = summonBtn.AbsolutePosition + (summonBtn.AbsoluteSize / 2) + Vector2.new(0, 36)
            SmoothMouseMoveToAbsolute(center, 0.5)
            task.wait(1)
            vim:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 1)
            task.wait(0.05)
            vim:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 1)
            
            task.wait(1)
            if not Settings.SGR.autoWaveEnabled then return end
            
            -- SUMMON 클릭 성공 후 A키 5초 유지
            vim:SendKeyEvent(true, Enum.KeyCode.A, false, game)
            task.wait(5)
            vim:SendKeyEvent(false, Enum.KeyCode.A, false, game)
            
            -- 오토마우스 시작 시 보스 속박 자동 활성화
            if bossBindToggleObj and not Settings.SGR.bossBindEnabled then
                Settings.SGR.bossBindEnabled = true
                pcall(function() bossBindToggleObj:SetState(true) end)
            end

            -- 오토마우스 시작 시 캐릭터 7초당 1바퀴 느리게 회전
            task.spawn(function()
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local d_hum = char and char:FindFirstChild("Humanoid")
                if not hrp or not d_hum then return end
                d_hum.AutoRotate = false
                
                local conn
                conn = game:GetService("RunService").RenderStepped:Connect(function(dt)
                    if not Settings.SGR.autoWaveEnabled or d_hum.Health <= 0 then
                        d_hum.AutoRotate = true
                        if conn then conn:Disconnect() end
                        return
                    end
                    if not Settings.SGR.isAlteredOrbActive then
                        hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(360 / 7) * dt, 0)
                    end
                end)
            end)
            
            -- [NEW] Special Orb 실시간 감지 및 텔레포트 (예측 제거)
            task.spawn(function()
                local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                local hrp = char:WaitForChild("HumanoidRootPart", 5)
                local hum = char:WaitForChild("Humanoid", 5)
                if not hrp or not hum then return end
                
                local entities = workspace:FindFirstChild("Entities")
                local specialOrbs = {"Altered Orb", "Plorb", "Chorber", "Orb", "Enlightened Orb", "Repressed Orb", "Synthesis Orb", "GunsForGuns Orb"}
                local wasBossBindEnabledBefore = false
                
                while Settings.SGR.autoWaveEnabled and hum.Health > 0 do
                    local targetOrb = nil
                    if entities then
                        for _, orbName in ipairs(specialOrbs) do
                            local found = entities:FindFirstChild(orbName)
                            if found then
                                targetOrb = found
                                break
                            end
                        end
                    end

                    if targetOrb then
                        local t_hum = targetOrb:FindFirstChildOfClass("Humanoid")
                        -- Humanoid가 사라지거나(Destroy) 체력이 0이 되면 즉시 추적 중단
                        if not t_hum or t_hum.Health <= 0 then
                            -- 대상 엔티티의 모든 부위 충돌 끄기 (Noclip)
                            pcall(function()
                                for _, part in ipairs(targetOrb:GetDescendants()) do
                                    if part:IsA("BasePart") then
                                        part.CanCollide = false
                                    end
                                end
                            end)
                            targetOrb = nil
                        end
                    end

                    if targetOrb then
                        -- 보스 속박이 켜져있다면 끄기 (비주얼/로직 동기화)
                        if Settings.SGR.bossBindEnabled then
                            wasBossBindEnabledBefore = true
                            Settings.SGR.bossBindEnabled = false
                            if bossBindToggleObj then pcall(function() bossBindToggleObj:SetState(false) end) end
                        end

                        Settings.SGR.isAlteredOrbActive = true
                        local currentOrbPos = targetOrb:GetPivot().Position
                        hrp.CFrame = CFrame.new(currentOrbPos + Vector3.new(0, 3, 0)) * (hrp.CFrame - hrp.CFrame.Position)
                    else
                        -- 보스 속박이 원래 켜져있었다면 다시 켜기
                        if wasBossBindEnabledBefore and not Settings.SGR.bossBindEnabled then
                            wasBossBindEnabledBefore = false
                            Settings.SGR.bossBindEnabled = true
                            if bossBindToggleObj then pcall(function() bossBindToggleObj:SetState(true) end) end
                        end

                        Settings.SGR.isAlteredOrbActive = false
                    end
                    task.wait()
                end
                Settings.SGR.isAlteredOrbActive = false
                
                -- 종료 시 원복 (안전장치)
                if wasBossBindEnabledBefore and not Settings.SGR.bossBindEnabled then
                    Settings.SGR.bossBindEnabled = true
                    if bossBindToggleObj then pcall(function() bossBindToggleObj:SetState(true) end) end
                end
            end)
            
            -- 죽을 때까지 0.1초마다 현재 마우스 위치에 오토마우스(클릭)
            while Settings.SGR.autoWaveEnabled do
                local currentHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
