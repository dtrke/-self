    for _, frame in ipairs({UIElements.leftFrame, UIElements.rightFrame}) do
        for _, v in ipairs(frame:GetDescendants()) do
            if v:IsA("TextLabel") then
                Services.TweenService:Create(v, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
            elseif v:IsA("Frame") then
                Services.TweenService:Create(v, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
