    Callback = function()
        local DeleteTool = Instance.new("Tool")
        DeleteTool.Name = "Delete tool"
        DeleteTool.RequiresHandle = false
        DeleteTool.CanBeDropped = false
        DeleteTool.Parent = LocalPlayer:WaitForChild("Backpack")

        local Mouse = LocalPlayer:GetMouse()
        local Highlight = Instance.new("Highlight", game:GetService("CoreGui"))
        Highlight.Enabled = false
        Highlight.FillTransparency = 1
        Highlight.OutlineTransparency = 0

        local RED = Color3.fromRGB(255, 0, 0)
        local BLUE = Color3.fromRGB(0, 85, 255)
        local currentTarget, renderConn, timeAcc = nil, nil, 0
        local undoStack = {}

        local function IsCharacterPart(part)
            local char = LocalPlayer.Character
            return char and part:IsDescendantOf(char)
        end

        local function CleanupHighlight()
            currentTarget = nil
            Highlight.Enabled = false
            Highlight.Adornee = nil
            if renderConn then
                renderConn:Disconnect()
                renderConn = nil
            end
        end

        local function StartHighlight(part)
            CleanupHighlight()
            currentTarget = part
            Highlight.Adornee = part
            Highlight.Enabled = true
            timeAcc = 0
            renderConn = Services.RunService.RenderStepped:Connect(function(dt)
                timeAcc += dt
                Highlight.OutlineColor = RED:Lerp(BLUE, (math.sin(timeAcc * 2) + 1) / 2)
            end)
        end

        Mouse.Move:Connect(function()
            if DeleteTool.Parent ~= LocalPlayer.Character then
                CleanupHighlight()
                return
            end
            local target = Mouse.Target
            if target and target:IsA("BasePart") and not IsCharacterPart(target) then
                if currentTarget ~= target then
                    StartHighlight(target)
                end
            else
                CleanupHighlight()
            end
        end)
    end
})

