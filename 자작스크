local function PulseHUD(isWeak, customColor)
    if not UIElements.hpBack then return end
    
    local pulse = Instance.new("Frame")
    pulse.Name = "PulseEffect"
    pulse.Parent = UIElements.hpBack
    pulse.ZIndex = 0
    pulse.BackgroundColor3 = customColor or Color3.fromRGB(200, 0, 0) -- 기본값은 빨간색
    pulse.BorderSizePixel = 0
    pulse.AnchorPoint = Vector2.new(0.5, 0.5)
    pulse.Position = UDim2.new(0.5, 0, 0.5, 0)
    pulse.Size = UDim2.new(1, 0, 1, 0)
    
    local duration = 1.2
    local sizeScale = 1
    local transparency = 0.2 -- 초기 투명도를 낮추어 색상을 더 진하게 표현
    
    if isWeak then
        -- 지속적인 잔상 펄스 (가시성 대폭 강화)
        duration = (1.2 / 1.7) * 1.3 
        sizeScale = 0.8 -- 기존 0.9에서 1.2배 축소 (0.9 / 1.2 = 0.75)
        transparency = 0.4 -- 작은 파동도 더 잘 보이게 투명도 조정
    else
        -- HP 30% 이하 처음 진입 시 (강력한 펄스 - 1.2배 크기, 1.3배 유지시간 증가)
        duration = 2.34 * 1.5 * 1.3 -- 기존 2.34 * 1.5초에서 1.3배 추가 증가
        sizeScale = 1.3 * 1.2 * 1.2 -- 기존 1.3 * 1.2에서 1.2배 추가 증가
        transparency = 0.2
    end
    
    pulse.BackgroundTransparency = transparency
    
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
    local goal = {
        Size = UDim2.new(1 + (0.15 * sizeScale), 0, 1 + (1.8 * sizeScale), 0),
        BackgroundTransparency = 1
    }
    
    local tween = Services.TweenService:Create(pulse, tweenInfo, goal)
    tween:Play()
    Services.Debris:AddItem(pulse, duration)
end

